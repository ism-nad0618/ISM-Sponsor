@model List<ISMSponsor.Models.Domain.LogCoverage>
@{
    Layout = "_Layout";
    ViewData["Title"] = "LoG Activity Report";
    var filters = ViewBag.Filters as ISMSponsor.ViewModels.ReportFilterViewModel ?? new ISMSponsor.ViewModels.ReportFilterViewModel();
    var totalCount = ViewBag.TotalCount ?? 0;
    var activeCount = ViewBag.ActiveCount ?? 0;
    var inactiveCount = ViewBag.InactiveCount ?? 0;
}

<div class="page-header">
    <div>
        <h1>LoG Activity Report</h1>
        <p class="page-subtitle">Letters of Guarantee status, approvals, and coverage tracking</p>
    </div>
    <div>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Back to Reports Hub</a>
    </div>
</div>

@{
    ViewBag.SummaryTitle = "Summary Statistics";
    ViewBag.SummaryMetrics = new Dictionary<string, object>
    {
        { "Total LoGs", totalCount },
        { "Active LoGs", activeCount },
        { "Inactive LoGs", inactiveCount },
        { "Approved", Model.Count(l => l.LogStatus == "Approved") },
        { "Pending", Model.Count(l => l.LogStatus == "Draft" || l.LogStatus == "Submitted") },
        { "Generated At", DateTime.Now.ToString("MMM d, yyyy h:mm tt") }
    };
}
@await Html.PartialAsync("_ReportSummary")

@{
    ViewBag.ShowSponsorFilter = true;
    ViewBag.ShowStudentFilter = false;
    ViewBag.ShowStatusFilter = true;
    ViewBag.ShowDateRangeFilter = true;
    ViewBag.FormAction = Url.Action("LogActivity");
}
@await Html.PartialAsync("_ReportFilters", filters)

@if (!Model.Any())
{
    @await Html.PartialAsync("_ReportNoData")
}
else
{
    <div class="card">
        <h2 class="table-title">LoG Details (@Model.Count LoGs)</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>LoG ID</th>
                        <th>Student ID</th>
                        <th>Student Name</th>
                        <th>Sponsor</th>
                        <th>Status</th>
                        <th>Active</th>
                        <th>Rules</th>
                        <th>Created On</th>
                        <th>Activated On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td><strong>@log.LogId</strong></td>
                            <td>@log.StudentId</td>
                            <td>
                                @if (log.Student != null)
                                {
                                    @($"{log.Student.FirstName} {log.Student.LastName}")
                                }
                                else
                                {
                                    <span style="color: #999;">N/A</span>
                                }
                            </td>
                            <td>
                                @if (log.Sponsor != null)
                                {
                                    @log.Sponsor.SponsorName
                                }
                                else
                                {
                                    @log.SponsorId
                                }
                            </td>
                            <td>
                                <span class="status-badge status-@log.LogStatus.ToLower()">@log.LogStatus</span>
                            </td>
                            <td>
                                @if (log.IsActive)
                                {
                                    <span class="status-badge status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                            </td>
                            <td>@(log.CoverageRules?.Count ?? 0)</td>
                            <td>@log.CreatedOn.ToString("MMM d, yyyy")</td>
                            <td>
                                @if (log.ActivatedOn.HasValue)
                                {
                                    @log.ActivatedOn.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span style="color: #999;">Not activated</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "LetterOfGuarantee", new { id = log.LogId })" class="link">View Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
