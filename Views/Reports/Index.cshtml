@{
    Layout = "_Layout";
    ViewData["Title"] = "Reports";
    var isAdmin = User.IsInRole("admin");
    var isAdmissions = User.IsInRole("admissions");
    var isCashier = User.IsInRole("cashier");
    var isSponsor = User.IsInRole("sponsor");
}

<div class="page-header">
    <div>
        <h1>Reports</h1>
        <p class="page-subtitle">All available reports for your role</p>
    </div>
</div>

<style>
    .report-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }
    .report-item {
        border: 1px solid #e1e4e8;
        border-radius: 6px;
        padding: 1rem;
        background: #fff;
        transition: all 0.2s;
        display: flex;
        flex-direction: column;
    }
    .report-item:hover {
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        transform: translateY(-2px);
    }
    .report-title {
        font-size: 0.95rem;
        font-weight: 600;
        margin: 0 0 0.5rem 0;
        color: #24292e;
    }
    .report-desc {
        font-size: 0.8rem;
        color: #666;
        margin: 0 0 0.75rem 0;
        flex: 1;
        line-height: 1.3;
    }
</style>

<div class="report-grid">
    
    @* Sponsor Reports *@
    @if (isSponsor)
    {
        <div class="report-item">
            <h3 class="report-title">My Letters of Guarantee</h3>
            <p class="report-desc">View all your LoGs with status and coverage details</p>
            <a href="@Url.Action("MyLoGs", "SponsorReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
        <div class="report-item">
            <h3 class="report-title">My Students</h3>
            <p class="report-desc">Roster of students you sponsor with enrollment details</p>
            <a href="@Url.Action("MyStudents", "SponsorReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
    }

    @* Admin Reports *@
    @if (isAdmin)
    {
        <div class="report-item">
            <h3 class="report-title">LoG Activity</h3>
            <p class="report-desc">Track LoG status, approvals, and coverage rules</p>
            <a href="@Url.Action("LogActivity", "AdminReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
        <div class="report-item">
            <h3 class="report-title">Coverage Decisions</h3>
            <p class="report-desc">Analyze coverage evaluations and outcomes</p>
            <a href="@Url.Action("CoverageDecisions", "AdminReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
        <div class="report-item">
            <h3 class="report-title">Sponsor Master</h3>
            <p class="report-desc">Complete sponsor roster with activity metrics</p>
            <a href="@Url.Action("SponsorMaster", "AdminReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
        <div class="report-item">
            <h3 class="report-title">Sync Status</h3>
            <p class="report-desc">Integration sync attempts and success rates</p>
            <a href="@Url.Action("SyncStatus", "AdminReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
        <div class="report-item">
            <h3 class="report-title">Audit Activity</h3>
            <p class="report-desc">System activity log with user actions</p>
            <a href="@Url.Action("AuditActivity", "AdminReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
    }

    @* Cashier Reports *@
    @if (isAdmin || isCashier)
    {
        <div class="report-item">
            <h3 class="report-title">Reconciliation Report</h3>
            <p class="report-desc">Billing reconciliation with coverage decisions and LoG status</p>
            <a href="@Url.Action("ReconciliationReport", "CashierReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
    }

    @* Admissions Reports *@
    @if (isAdmin || isAdmissions)
    {
        <div class="report-item">
            <h3 class="report-title">Coverage Tracking</h3>
            <p class="report-desc">Track coverage alignment by sponsor with progress metrics</p>
            <a href="@Url.Action("TrackingReport", "AdmissionsReports")" class="btn btn-primary btn-sm">View Report</a>
        </div>
    }
    
</div>
