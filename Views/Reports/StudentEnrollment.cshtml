@model List<ISMSponsor.Models.Domain.Student>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Student Enrollment Report";
    var filters = ViewBag.Filters as ISMSponsor.ViewModels.ReportFilterViewModel ?? new ISMSponsor.ViewModels.ReportFilterViewModel();
    var totalCount = ViewBag.TotalCount ?? 0;
    var activeCount = ViewBag.ActiveCount ?? 0;
}

<div class="page-header">
    <div>
        <h1>Student Enrollment Report</h1>
        <p class="page-subtitle">Student roster by sponsor with grade levels and enrollment status</p>
    </div>
    <div>
        <a href="@Url.Action("Index")" class="btn btn-secondary">← Back to Reports Hub</a>
    </div>
</div>

@{
    ViewBag.SummaryTitle = "Summary Statistics";
    ViewBag.SummaryMetrics = new Dictionary<string, object>
    {
        { "Total Students", totalCount },
        { "Active Students", activeCount },
        { "Generated At", DateTime.Now.ToString("MMM d, yyyy h:mm tt") }
    };
}
@await Html.PartialAsync("_ReportSummary")

@{
    ViewBag.ShowSponsorFilter = true;
    ViewBag.ShowStudentFilter = false;
    ViewBag.ShowStatusFilter = true;
    ViewBag.ShowDateRangeFilter = false;
    ViewBag.FormAction = Url.Action("StudentEnrollment");
}
@await Html.PartialAsync("_ReportFilters", filters)

@if (!Model.Any())
{
    @await Html.PartialAsync("_ReportNoData")
}
else
{
    <div class="card">
        <h2 class="table-title">Student Details (@Model.Count students)</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Name</th>
                        <th>Grade Level</th>
                        <th>Sponsor</th>
                        <th>Status</th>
                        <th>School Year</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td><strong>@student.StudentId</strong></td>
                            <td>@student.FirstName @student.LastName</td>
                            <td><span class="grade-badge">Grade @student.GradeLevel</span></td>
                            <td>
                                @if (student.Sponsor != null)
                                {
                                    @student.Sponsor.SponsorName
                                }
                                else
                                {
                                    @student.SponsorId
                                }
                            </td>
                            <td>
                                <span class="status-badge status-@student.StudentStatus.ToLower()">
                                    @student.StudentStatus
                                </span>
                            </td>
                            <td>@student.SchoolYearId</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
