@model ISMSponsor.Models.Domain.ActivityLog
@{
    ViewData["Title"] = "Audit Details";
    var coverageEvaluation = ViewBag.CoverageEvaluation as ISMSponsor.Models.Domain.CoverageEvaluationAudit;
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Audit Record Details</h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Activity Log #@Model.ActivityLogId</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Timestamp</dt>
                        <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                        <dt class="col-sm-3">Module</dt>
                        <dd class="col-sm-9"><span class="badge bg-info">@Model.Item</span></dd>

                        <dt class="col-sm-3">Actor</dt>
                        <dd class="col-sm-9">@Model.UserDisplay</dd>

                        <dt class="col-sm-3">Role</dt>
                        <dd class="col-sm-9"><span class="badge bg-secondary">@Model.RoleName</span></dd>

                        <dt class="col-sm-3">School Year</dt>
                        <dd class="col-sm-9">@Model.SchoolYearId</dd>

                        <dt class="col-sm-3">Details</dt>
                        <dd class="col-sm-9">
                            <div class="alert alert-light">
                                @Model.Details
                            </div>
                        </dd>
                    </dl>
                </div>
            </div>

            @if (coverageEvaluation != null)
            {
                <div class="card mt-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Coverage Evaluation Details</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Evaluation ID</dt>
                            <dd class="col-sm-9">@coverageEvaluation.AuditId</dd>

                            <dt class="col-sm-3">Evaluated At</dt>
                            <dd class="col-sm-9">@coverageEvaluation.EvaluatedOn.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                            <dt class="col-sm-3">School Year</dt>
                            <dd class="col-sm-9">@coverageEvaluation.SchoolYearId</dd>

                            <dt class="col-sm-3">Sponsor ID</dt>
                            <dd class="col-sm-9">@coverageEvaluation.SponsorId</dd>

                            <dt class="col-sm-3">Student ID</dt>
                            <dd class="col-sm-9">@coverageEvaluation.StudentId</dd>

                            <dt class="col-sm-3">Item ID</dt>
                            <dd class="col-sm-9">@coverageEvaluation.ItemId</dd>

                            <dt class="col-sm-3">Transaction Amount</dt>
                            <dd class="col-sm-9">@coverageEvaluation.RequestedAmount.ToString("C")</dd>

                            <dt class="col-sm-3">Decision</dt>
                            <dd class="col-sm-9">
                                <span class="badge @(coverageEvaluation.Decision == "Covered" ? "bg-success" : "bg-danger")">
                                    @coverageEvaluation.Decision
                                </span>
                            </dd>

                            <dt class="col-sm-3">Bill To</dt>
                            <dd class="col-sm-9">
                                <span class="badge bg-info">@coverageEvaluation.BillTo</span>
                            </dd>

                            <dt class="col-sm-3">Reason Code</dt>
                            <dd class="col-sm-9">
                                <span class="badge bg-warning text-dark">@coverageEvaluation.ReasonCode</span>
                            </dd>

                            <dt class="col-sm-3">Rule Version</dt>
                            <dd class="col-sm-9">@coverageEvaluation.RuleVersion</dd>

                            <dt class="col-sm-3">Input Payload</dt>
                            <dd class="col-sm-9">
                                <div class="alert alert-light">
                                    <div>School Year: @coverageEvaluation.SchoolYearId, Student: @coverageEvaluation.StudentId, Item: @coverageEvaluation.ItemId, Amount: @coverageEvaluation.RequestedAmount.ToString("C")</div>
                                </div>
                            </dd>

                            <dt class="col-sm-3">Output Payload</dt>
                            <dd class="col-sm-9">
                                <div class="alert alert-light">
                                    <div>Decision: @coverageEvaluation.Decision, Bill To: @coverageEvaluation.BillTo, Reason: @coverageEvaluation.ReasonCode</div>
                                </div>
                            </dd>
                        </dl>
                    </div>
                </div>
            }

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>
