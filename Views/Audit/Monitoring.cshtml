@{
    ViewData["Title"] = "System Monitoring";
    var recentFailures = ViewBag.RecentFailures as List<ISMSponsor.Models.Domain.ActivityLog> ?? new List<ISMSponsor.Models.Domain.ActivityLog>();
    var recentCoverageEvaluations = ViewBag.RecentCoverageEvaluations as List<ISMSponsor.Models.Domain.CoverageEvaluationAudit> ?? new List<ISMSponsor.Models.Domain.CoverageEvaluationAudit>();
    var stats = ViewBag.Statistics as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>System Monitoring</h2>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Audit Log
                </a>
            </div>

            <!-- Statistics Cards -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card text-white bg-primary">
                        <div class="card-body">
                            <h5 class="card-title">Total Actions (7 days)</h5>
                            <p class="card-text display-4">@(stats.ContainsKey("TotalActions") ? stats["TotalActions"] : 0)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-success">
                        <div class="card-body">
                            <h5 class="card-title">Coverage Evaluations</h5>
                            <p class="card-text display-4">@(stats.ContainsKey("CoverageEvaluations") ? stats["CoverageEvaluations"] : 0)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-info">
                        <div class="card-body">
                            <h5 class="card-title">Sponsor Requests</h5>
                            <p class="card-text display-4">@(stats.ContainsKey("SponsorRequests") ? stats["SponsorRequests"] : 0)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-warning">
                        <div class="card-body">
                            <h5 class="card-title">LoG Actions</h5>
                            <p class="card-text display-4">@(stats.ContainsKey("LoGActions") ? stats["LoGActions"] : 0)</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Failures -->
            <div class="card mb-4">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Recent Failures</h5>
                </div>
                <div class="card-body">
                    @if (recentFailures.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Module</th>
                                        <th>Actor</th>
                                        <th>Details</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var failure in recentFailures)
                                    {
                                        <tr>
                                            <td>@failure.Date.ToString("MM/dd HH:mm")</td>
                                            <td><span class="badge bg-danger">@failure.Item</span></td>
                                            <td>@failure.UserDisplay</td>
                                            <td class="text-truncate" style="max-width: 300px;">@failure.Details</td>
                                            <td>
                                                <a asp-action="Details" asp-route-id="@failure.ActivityLogId" class="btn btn-sm btn-outline-primary">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">
                            <i class="bi bi-check-circle"></i> No recent failures detected.
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Coverage Evaluations -->
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Recent Coverage Evaluations</h5>
                </div>
                <div class="card-body">
                    @if (recentCoverageEvaluations.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Date</th>
                                        <th>Sponsor</th>
                                        <th>Student</th>
                                        <th>Item</th>
                                        <th>Amount</th>
                                        <th>Decision</th>
                                        <th>Reason Code</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var eval in recentCoverageEvaluations)
                                    {
                                        <tr>
                                            <td>@eval.AuditId</td>
                                            <td>@eval.EvaluatedOn.ToString("MM/dd HH:mm")</td>
                                            <td>@eval.SponsorId</td>
                                            <td>@eval.StudentId</td>
                                            <td>@eval.ItemId</td>
                                            <td>@eval.RequestedAmount.ToString("C")</td>
                                            <td>
                                                <span class="badge @(eval.Decision == "Covered" ? "bg-success" : "bg-danger")">
                                                    @eval.Decision
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-warning text-dark">@eval.ReasonCode</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> No coverage evaluations yet.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
