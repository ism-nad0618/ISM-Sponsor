@model ISMSponsor.ViewModels.PortalHomeViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sponsor Portal";
}

<div class="page-header">
    <div>
        <h1>Welcome, @Model.Sponsor.SponsorName</h1>
        <p class="page-subtitle">School Year: <strong>@Model.SelectedSchoolYearName</strong></p>
    </div>
</div>

<!-- Key Metrics -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Your Students</div>
        <div class="stat-value">@Model.StudentCount</div>
        <div class="stat-footer">
            <a href="@Url.Action("Students")" class="link">View All →</a>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Active LoGs</div>
        <div class="stat-value">@Model.ActiveLoGCount</div>
        <div class="stat-footer">
            <a href="@Url.Action("LettersOfGuarantee")" class="link">View All →</a>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Pending Requests</div>
        <div class="stat-value">@Model.PendingRequestCount</div>
        <div class="stat-footer">
            <a href="@Url.Action("Requests")" class="link">View All →</a>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card">
    <h2 class="table-title">Quick Actions</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; padding: 1rem 0;">
        <a href="@Url.Action("LettersOfGuarantee")" class="btn btn-primary" style="text-align: center;">
             View Letters of Guarantee
        </a>
        <a href="@Url.Action("Students")" class="btn btn-secondary" style="text-align: center;">
            View Students
        </a>
        <a href="@Url.Action("Requests")" class="btn btn-secondary" style="text-align: center;">
             View Change Requests
        </a>
        <a href="@Url.Action("Contacts")" class="btn btn-secondary" style="text-align: center;">
             Manage Contacts
        </a>
        <a href="@Url.Action("Profile")" class="btn btn-secondary" style="text-align: center;">
             View Profile
        </a>
    </div>
</div>

<!-- Recent Letters of Guarantee -->
<div class="card">
    <h2 class="table-title">Recent Letters of Guarantee</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>Student Name</th>
                    <th>Status</th>
                    <th>Active</th>
                    <th>Created On</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.RecentLoGs.Any())
                {
                    <tr>
                        <td colspan="6" class="empty-state">No Letters of Guarantee found for this school year.</td>
                    </tr>
                }
                else
                {
                    foreach (var log in Model.RecentLoGs)
                    {
                        <tr>
                            <td><strong>@log.StudentId</strong></td>
                            <td>@(log.Student != null ? $"{log.Student.FirstName} {log.Student.LastName}" : "N/A")</td>
                            <td>
                                <span class="status-badge status-@log.LogStatus.ToLower()">@log.LogStatus</span>
                            </td>
                            <td>
                                @if (log.IsActive)
                                {
                                    <span class="status-badge status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                            </td>
                            <td>@log.CreatedOn.ToString("MMM d, yyyy")</td>
                            <td>
                                <a href="@Url.Action("LoGDetail", new { id = log.LogId })" class="link">View Details</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @if (Model.RecentLoGs.Any())
    {
        <div style="text-align: center; padding: 1rem;">
            <a href="@Url.Action("LettersOfGuarantee")" class="btn btn-secondary">View All Letters of Guarantee</a>
        </div>
    }
</div>

<!-- Recent Change Requests -->
<div class="card">
    <h2 class="table-title">Recent Change Requests</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Field</th>
                    <th>Current Value</th>
                    <th>Requested Value</th>
                    <th>Status</th>
                    <th>Requested On</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.RecentRequests.Any())
                {
                    <tr>
                        <td colspan="5" class="empty-state">No change requests submitted yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var request in Model.RecentRequests)
                    {
                        <tr>
                            <td><strong>@request.RequestField</strong></td>
                            <td>@request.CurrentValue</td>
                            <td>@request.RequestedValue</td>
                            <td>
                                <span class="status-badge status-@request.Status.ToLower()">
                                    @request.Status.ToUpper()
                                </span>
                            </td>
                            <td>@request.SubmittedOn.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @if (Model.RecentRequests.Any())
    {
        <div style="text-align: center; padding: 1rem;">
            <a href="@Url.Action("Requests")" class="btn btn-secondary">View All Requests</a>
        </div>
    }
</div>
