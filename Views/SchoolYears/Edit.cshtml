@model ISMSponsor.Models.Domain.SchoolYear
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit School Year";
}

<div class="page-header">
    <h1>Edit School Year</h1>
    <p class="page-subtitle">Modify details for school year @Model.SchoolYearId.</p>
</div>

@if (TempData["Error"] is string errorText)
{
    <div class="alert alert-error">@errorText</div>
}

<div class="card">
    <form method="post" asp-action="Edit">
        @Html.AntiForgeryToken()
        
        <div class="form-group">
            <label asp-for="SchoolYearId" class="field-label">School Year ID</label>
            <input asp-for="SchoolYearId" class="form-control" readonly style="background: #f0f0f0;" />
            <small class="form-text">School Year ID cannot be changed</small>
        </div>

        <div class="form-group">
            <label asp-for="Name" class="field-label">Name</label>
            <input asp-for="Name" class="form-control" placeholder="e.g., School Year 2025-2026" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ValidFrom" class="field-label">Valid From</label>
            <input asp-for="ValidFrom" type="date" class="form-control" required />
            <span asp-validation-for="ValidFrom" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ValidTo" class="field-label">Valid To</label>
            <input asp-for="ValidTo" type="date" class="form-control" required />
            <span asp-validation-for="ValidTo" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="field-label">
                <input asp-for="IsActive" type="checkbox" />
                Set as Active School Year
            </label>
            <span asp-validation-for="IsActive" class="text-danger"></span>
            <small class="form-text">Only one school year can be active at a time</small>
        </div>

        <div class="form-actions" style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" style="background: #2d5a8c; color: white; padding: 0.75rem 1.5rem; border: none; border-radius: 4px; cursor: pointer;">Save Changes</button>
            <a asp-action="Index" style="background: #6c757d; color: white; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 4px; display: inline-block;">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
