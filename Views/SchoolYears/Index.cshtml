@model List<ISMSponsor.Models.Domain.SchoolYear>
@{
    Layout = "_Layout";
    ViewData["Title"] = "School Years";
}

<div class="page-header">
    <h1>School Years</h1>
    <p class="page-subtitle">Manage school year records and active year status.</p>
</div>

@if (TempData["Error"] is string errorText)
{
    <div class="alert alert-error">@errorText</div>
}

@if (TempData["Success"] is string successText)
{
    <div class="alert alert-success">@successText</div>
}

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <h2 class="table-title">School Year Directory</h2>
        <a asp-action="Create" class="btn-primary" style="background: #2d5a8c; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px;">+ Add School Year</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>School Year ID</th>
                    <th>Name</th>
                    <th>Valid From</th>
                    <th>Valid To</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var y in Model)
                {
                    <tr>
                        <td><strong>@y.SchoolYearId</strong></td>
                        <td>@y.Name</td>
                        <td>@y.ValidFrom.ToString("MMMM d, yyyy")</td>
                        <td>@y.ValidTo.ToString("MMMM d, yyyy")</td>
                        <td>
                            @if (y.IsActive)
                            {
                                <span class="badge badge-approved">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-draft">Inactive</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 0.5rem;">
                                @if (!y.IsActive)
                                {
                                    <form method="post" asp-action="SetActive" style="display: inline;">
                                        <input type="hidden" name="id" value="@y.SchoolYearId" />
                                        <button type="submit" style="background: #28a745;">Set Active</button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color: #28a745; font-weight: 500;">Current</span>
                                }
                                <a asp-action="Edit" asp-route-id="@y.SchoolYearId" style="background: #ffc107; color: #000; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; display: inline-block;">Edit</a>
                                <form method="post" asp-action="Delete" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this school year?');">
                                    <input type="hidden" name="id" value="@y.SchoolYearId" />
                                    <button type="submit" style="background: #dc3545; color: white;">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
