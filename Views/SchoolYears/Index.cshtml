@model List<ISMSponsor.Models.Domain.SchoolYear>
@{
    Layout = "_Layout";
    ViewData["Title"] = "School Years";
}

<div class="page-header">
    <h1>School Years</h1>
    <p class="page-subtitle">Manage school year records and active year status.</p>
</div>

@if (TempData["Error"] is string errorText)
{
    <div class="alert alert-error">@errorText</div>
}

@if (TempData["Success"] is string successText)
{
    <div class="alert alert-success">@successText</div>
}

<div class="card">
    <div class="page-header-actions">
        <h2 class="table-title">School Year Directory</h2>
        <button type="button" class="btn-primary btn-add" onclick="openCreateModal()">+ Add School Year</button>
    </div>
    <div class="table-wrap">
        <table>
        <thead>
            <tr>
                <th>School Year ID</th>
                <th>Name</th>
                <th>Valid From</th>
                <th>Valid To</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var y in Model)
            {
                <tr data-id="@y.SchoolYearId">
                    <td><strong class="view-mode">@y.SchoolYearId</strong></td>
                    <td>
                        <span class="view-mode">@y.Name</span>
                        <input type="text" class="edit-mode" value="@y.Name" data-field="Name" style="display:none; width: 100%;" />
                    </td>
                    <td>
                        <span class="view-mode">@y.ValidFrom.ToString("MMMM d, yyyy")</span>
                        <input type="date" class="edit-mode" value="@y.ValidFrom.ToString("yyyy-MM-dd")" data-field="ValidFrom" style="display:none; width: 100%;" />
                    </td>
                    <td>
                        <span class="view-mode">@y.ValidTo.ToString("MMMM d, yyyy")</span>
                        <input type="date" class="edit-mode" value="@y.ValidTo.ToString("yyyy-MM-dd")" data-field="ValidTo" style="display:none; width: 100%;" />
                    </td>
                    <td>
                        <span class="status-badge @(y.IsActive ? "status-active" : "status-inactive")">
                            @(y.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td data-label="Actions" class="action-cell">
                        <div class="view-mode">
                            @if (!y.IsActive)
                            {
                                <form method="post" asp-action="SetActive" class="d-inline">
                                    <input type="hidden" name="id" value="@y.SchoolYearId" />
                                    <button type="submit" class="btn-link">Set Active</button>
                                </form>
                            }
                            <a href="javascript:void(0)" class="btn-link btn-edit" data-id="@y.SchoolYearId">Edit</a>
                            <form method="post" asp-action="Delete" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this school year?');">
                                <input type="hidden" name="id" value="@y.SchoolYearId" />
                                <button type="submit" class="btn-link-delete">Delete</button>
                            </form>
                        </div>
                        <div class="edit-mode" style="display:none;">
                            <a href="javascript:void(0)" class="btn-link btn-save" data-id="@y.SchoolYearId" style="color: green;">Save</a>
                            <a href="javascript:void(0)" class="btn-link btn-cancel" data-id="@y.SchoolYearId" style="color: red;">Cancel</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>

<!-- Create School Year Modal -->
<div id="createSchoolYearModal" class="modal">
    <div class="modal-content" style="max-width: 600px;">
        <div class="modal-header">
            <div>
                <h2 style="margin: 0;">Create New School Year</h2>
                <p style="color: var(--gray-600); margin: 4px 0 0 0; font-size: 14px;">Add a new school year to the system</p>
            </div>
            <button type="button" class="close" onclick="closeCreateModal()">&times;</button>
        </div>
        
        <div id="modalError" class="alert alert-error" style="display: none; margin-top: 16px;"></div>
        <div id="modalSuccess" class="alert alert-success" style="display: none; margin-top: 16px;"></div>
        
        <form id="createSchoolYearForm" style="margin-top: 16px;">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label class="field-label">School Year ID <span class="required">*</span></label>
                <input type="text" name="SchoolYearId" id="SchoolYearId" placeholder="e.g., 25-26" required />
                <span class="form-error" id="SchoolYearId-error"></span>
                <p class="help-text">Use format: YY-YY (e.g., 25-26 for 2025-2026)</p>
            </div>

            <div class="form-group">
                <label class="field-label">Name <span class="required">*</span></label>
                <input type="text" name="Name" id="Name" placeholder="e.g., School Year 2025-2026" required />
                <span class="form-error" id="Name-error"></span>
            </div>

            <div class="form-group">
                <label class="field-label">Valid From <span class="required">*</span></label>
                <input type="date" name="ValidFrom" id="ValidFrom" required />
                <span class="form-error" id="ValidFrom-error"></span>
            </div>

            <div class="form-group">
                <label class="field-label">Valid To <span class="required">*</span></label>
                <input type="date" name="ValidTo" id="ValidTo" required />
                <span class="form-error" id="ValidTo-error"></span>
            </div>

            <div class="form-group">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input type="checkbox" name="IsActive" id="IsActive" style="cursor: pointer; width: auto;" />
                    <span class="field-label" style="margin: 0;">Set as Active School Year</span>
                </label>
            </div>

            <div class="form-actions" style="margin-top: 24px;">
                <button type="button" class="btn-secondary btn-add" onclick="closeCreateModal()">Cancel</button>
                <button type="submit" class="btn-primary btn-add" id="createBtn"> Create School Year</button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Edit button click
    document.querySelectorAll('.btn-edit').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.getAttribute('data-id');
            const row = document.querySelector(`tr[data-id="${id}"]`);
            
            // Hide view mode, show edit mode
            row.querySelectorAll('.view-mode').forEach(el => el.style.display = 'none');
            row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'inline-block');
        });
    });
    
    // Cancel button click
    document.querySelectorAll('.btn-cancel').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.getAttribute('data-id');
            const row = document.querySelector(`tr[data-id="${id}"]`);
            
            // Show view mode, hide edit mode
            row.querySelectorAll('.view-mode').forEach(el => el.style.display = '');
            row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'none');
        });
    });
    
    // Save button click
    document.querySelectorAll('.btn-save').forEach(btn => {
        btn.addEventListener('click', async function() {
            const id = this.getAttribute('data-id');
            const row = document.querySelector(`tr[data-id="${id}"]`);
            
            // Collect data from input fields
            const data = {
                SchoolYearId: id,
                Name: row.querySelector('[data-field="Name"]').value,
                ValidFrom: row.querySelector('[data-field="ValidFrom"]').value,
                ValidTo: row.querySelector('[data-field="ValidTo"]').value,
                IsActive: row.querySelector('.status-badge').classList.contains('status-active')
            };
            
            try {
                const response = await fetch('/Settings/SchoolYears/EditInline', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Update view mode values
                    const nameView = row.querySelectorAll('.view-mode')[1];
                    nameView.textContent = data.Name;
                    
                    const validFromView = row.querySelectorAll('.view-mode')[2];
                    validFromView.textContent = new Date(data.ValidFrom).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                    
                    const validToView = row.querySelectorAll('.view-mode')[3];
                    validToView.textContent = new Date(data.ValidTo).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
                    
                    // Hide edit mode, show view mode
                    row.querySelectorAll('.view-mode').forEach(el => el.style.display = '');
                    row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'none');
                    
                    // Show success message
                    alert(result.message);
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while saving');
            }
        });
    });
});

// Modal functions
function openCreateModal() {
    document.getElementById('createSchoolYearModal').classList.add('active');
    document.getElementById('createSchoolYearForm').reset();
    document.getElementById('modalError').style.display = 'none';
    document.getElementById('modalSuccess').style.display = 'none';
    clearErrors();
}

function closeCreateModal() {
    document.getElementById('createSchoolYearModal').classList.remove('active');
}

function clearErrors() {
    document.querySelectorAll('.form-error').forEach(el => el.textContent = '');
}

// Handle form submission
document.getElementById('createSchoolYearForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    clearErrors();
    document.getElementById('modalError').style.display = 'none';
    document.getElementById('modalSuccess').style.display = 'none';
    
    const createBtn = document.getElementById('createBtn');
    const originalText = createBtn.innerHTML;
    createBtn.disabled = true;
    createBtn.innerHTML = 'Creating...';
    
    const formData = new FormData(this);
    
    try {
        const response = await fetch('/Settings/SchoolYears/CreateModal', {
            method: 'POST',
            body: formData
        });
        
        const result = await response.json();
        
        if (result.success) {
            document.getElementById('modalSuccess').textContent = result.message;
            document.getElementById('modalSuccess').style.display = 'block';
            
            // Reload page after short delay
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            if (result.validationErrors) {
                // Show field-specific errors
                for (const [field, errors] of Object.entries(result.validationErrors)) {
                    const errorElement = document.getElementById(`${field}-error`);
                    if (errorElement) {
                        errorElement.textContent = errors[0];
                    }
                }
            }
            
            const errorDiv = document.getElementById('modalError');
            errorDiv.textContent = result.message || 'Failed to create school year.';
            errorDiv.style.display = 'block';
        }
    } catch (error) {
        console.error('Error:', error);
        const errorDiv = document.getElementById('modalError');
        errorDiv.textContent = 'An error occurred while creating the school year.';
        errorDiv.style.display = 'block';
    } finally {
        createBtn.disabled = false;
        createBtn.innerHTML = originalText;
    }
});
</script>