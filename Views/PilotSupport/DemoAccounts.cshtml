            <tbody>
                <tr>
                    <td><code>DEMO-SP001</code></td>
                    <td>Global Tech Corporation</td>
                    <td><span class="badge bg-success">Active</span></td>
                    <td>Fully synced with PowerSchool and NetSuite. Has 2 active students, 1 active LoG.</td>
                </tr>
                <tr>
                    <td><code>DEMO-SP002</code></td>
                    <td>Asian Development Bank</td>
                    <td><span class="badge bg-success">Active</span></td>
