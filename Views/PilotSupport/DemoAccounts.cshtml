@{
    ViewData["Title"] = "Demo Accounts";
}

<div class="container mt-4">
    <h2><i class="bi bi-person-badge"></i> Demo Accounts</h2>
    <p class="lead">Test user accounts for UAT execution and training demos.</p>

    <div class="mb-3">
        <a href="@Url.Action("Index", "PilotSupport")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Pilot Support
        </a>
    </div>

    <hr />

    <div class="alert alert-warning">
        <h5 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> Important</h5>
        <ul class="mb-0">
            <li><strong>All demo accounts have the same password:</strong> <code>Demo@2026!</code></li>
            <li><strong>These accounts are for testing only</strong> and should not be used in production</li>
            <li><strong>Do not share these credentials</strong> outside the UAT team</li>
            <li><strong>Demo accounts are pre-seeded</strong> during database initialization</li>
        </ul>
    </div>

    <h4 class="mt-4">Demo User Accounts</h4>
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Email</th>
                    <th>Password</th>
                    <th>Role</th>
                    <th>Purpose</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>demo.admin@ism.edu.ph</code></td>
                    <td>
                        <code id="pwd-admin">Demo@2026!</code>
                        <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copyPassword('pwd-admin')">
                            <i class="bi bi-clipboard"></i> Copy
                        </button>
                    </td>
                    <td><span class="badge bg-danger">Admin</span></td>
                    <td>Full system access. Create/edit sponsors, approve requests, manage settings, view all reports.</td>
                    <td>
                        <a href="/Account/Login" class="btn btn-sm btn-primary">Login</a>
                    </td>
                </tr>
                <tr>
                    <td><code>demo.admissions@ism.edu.ph</code></td>
                    <td>
                        <code id="pwd-admissions">Demo@2026!</code>
                        <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copyPassword('pwd-admissions')">
                            <i class="bi bi-clipboard"></i> Copy
                        </button>
                    </td>
                    <td><span class="badge bg-warning">Admissions</span></td>
                    <td>Create sponsors, submit change requests, view students and LoGs. Cannot approve requests or edit settings.</td>
                    <td>
                        <a href="/Account/Login" class="btn btn-sm btn-primary">Login</a>
                    </td>
                </tr>
                <tr>
                    <td><code>demo.cashier@ism.edu.ph</code></td>
                    <td>
                        <code id="pwd-cashier">Demo@2026!</code>
                        <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copyPassword('pwd-cashier')">
                            <i class="bi bi-clipboard"></i> Copy
                        </button>
                    </td>
                    <td><span class="badge bg-info">Cashier</span></td>
                    <td>Read-only access. View sponsors, students, LoGs, coverage. Cannot create or edit.</td>
                    <td>
                        <a href="/Account/Login" class="btn btn-sm btn-primary">Login</a>
                    </td>
                </tr>
                <tr>
                    <td><code>demo.sponsor@ism.edu.ph</code></td>
                    <td>
                        <code id="pwd-sponsor">Demo@2026!</code>
                        <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copyPassword('pwd-sponsor')">
                            <i class="bi bi-clipboard"></i> Copy
                        </button>
                    </td>
                    <td><span class="badge bg-success">Sponsor</span></td>
                    <td>Sponsor self-service portal access (future phase). Currently limited access.</td>
                    <td>
                        <a href="/Account/Login" class="btn btn-sm btn-primary">Login</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

