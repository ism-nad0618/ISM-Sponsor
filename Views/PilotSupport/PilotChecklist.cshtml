@{
    ViewData["Title"] = "Pilot Readiness Checklist";
}

<div class="container mt-4">
    <h2><i class="bi bi-list-check"></i> Pilot Readiness Checklist</h2>
    <p class="lead">Final verification checklist before pilot deployment.</p>

    <div class="mb-3">
        <a href="@Url.Action("Index", "PilotSupport")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Pilot Support
        </a>
        <a href="~/docs/PILOT_READINESS_CHECKLIST.md" class="btn btn-success" download>
            <i class="bi bi-download"></i> Download Full Checklist
        </a>
    </div>

    <hr />

    <div class="alert alert-warning">
        <h5 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> Important</h5>
        <p class="mb-0">
            <strong>Critical items marked with are BLOCKING for pilot.</strong> All critical items must pass before deployment.
            Non-critical items should be addressed but do not block pilot launch if documented and mitigated.
        </p>
    </div>

    <!-- Progress Summary -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Checklist Progress</h5>
                    <p class="text-muted">This is a summary view. Download the full checklist for detailed verification.</p>
                    <div class="progress" style="height: 30px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progress-bar">
                            <span id="progress-text">0%</span>
                        </div>
                    </div>
                    <p class="mt-2 text-muted">
                        <span id="completed-count">0</span> of <span id="total-count">100+</span> items completed
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Section 1: Technical Infrastructure -->
    <div class="card mb-3">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-server"></i> 1. Technical Infrastructure</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Database deployed and accessible (Azure SQL or equivalent)</li>
                <li><input type="checkbox" class="checklist-item"> Web application deployed to staging/pilot environment</li>
                <li><input type="checkbox" class="checklist-item"> Application runs without errors on startup</li>
                <li><input type="checkbox" class="checklist-item"> Database migrations applied successfully</li>
                <li><input type="checkbox" class="checklist-item"> Demo data seeded (6 sponsors, 8 students, 5 LoGs)</li>
                <li><input type="checkbox" class="checklist-item"> HTTPS/TLS configured correctly</li>
                <li><input type="checkbox" class="checklist-item"> Environment variables configured (appsettings.Staging.json)</li>
                <li><input type="checkbox" class="checklist-item"> Connection strings secured (not in source control)</li>
                <li><input type="checkbox" class="checklist-item"> Backup and restore procedures documented</li>
                <li><input type="checkbox" class="checklist-item"> Rollback plan documented and tested</li>
            </ul>
        </div>
    </div>

    <!-- Section 2: Authentication and Security -->
    <div class="card mb-3">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-shield-lock"></i> 2. Authentication and Security</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> ASP.NET Core Identity configured and working</li>
                <li><input type="checkbox" class="checklist-item"> 4 demo user accounts created (Admin, Admissions, Cashier, Sponsor)</li>
                <li><input type="checkbox" class="checklist-item"> Role-based authorization working (Admin, Admissions, Cashier, Sponsor)</li>
                <li><input type="checkbox" class="checklist-item"> Admissions users cannot approve change requests</li>
                <li><input type="checkbox" class="checklist-item"> Cashier users have read-only access</li>
                <li><input type="checkbox" class="checklist-item"> Password policies enforced (complexity, length)</li>
                <li><input type="checkbox" class="checklist-item"> Session timeout configured (30 minutes idle)</li>
                <li><input type="checkbox" class="checklist-item"> Anti-forgery tokens enabled on forms</li>
                <li><input type="checkbox" class="checklist-item"> Audit logging captures all authentication events</li>
            </ul>
        </div>
    </div>

    <!-- Section 3: Core Functionality -->
    <div class="card mb-3">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0"><i class="bi bi-gear"></i> 3. Core Functionality</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Sponsor search and list view working</li>
                <li><input type="checkbox" class="checklist-item"> Sponsor create workflow working (Admin/Admissions)</li>
                <li><input type="checkbox" class="checklist-item"> Sponsor edit workflow working (Admin: direct, Admissions: change request)</li>
                <li><input type="checkbox" class="checklist-item"> Change request submission working (Admissions)</li>
                <li><input type="checkbox" class="checklist-item"> Change request approval working (Admin)</li>
                <li><input type="checkbox" class="checklist-item"> Change request rejection working (Admin)</li>
                <li><input type="checkbox" class="checklist-item"> LoG create/edit/activate working</li>
                <li><input type="checkbox" class="checklist-item"> Coverage rule definition working (Covered, Split, NotCovered)</li>
                <li><input type="checkbox" class="checklist-item"> Coverage evaluation working (manual trigger)</li>
                <li><input type="checkbox" class="checklist-item"> Duplicate sponsor detection working</li>
                <li><input type="checkbox" class="checklist-item"> Sponsor merge workflow working (Admin)</li>
                <li><input type="checkbox" class="checklist-item"> Student list and search working</li>
                <li><input type="checkbox" class="checklist-item"> School year selector working correctly</li>
                <li><input type="checkbox" class="checklist-item"> Validation messages clear and user-friendly</li>
                <li><input type="checkbox" class="checklist-item"> Error handling displays user-friendly messages</li>
            </ul>
        </div>
    </div>

    <!-- Section 4: Reporting and Monitoring -->
    <div class="card mb-3">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0"><i class="bi bi-graph-up"></i> 4. Reporting and Monitoring</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Admin Reports page accessible</li>
                <li><input type="checkbox" class="checklist-item"> Sponsor List Report working</li>
                <li><input type="checkbox" class="checklist-item"> LoG Summary Report working</li>
                <li><input type="checkbox" class="checklist-item"> Coverage Evaluation Report working</li>
                <li><input type="checkbox" class="checklist-item"> Sync Log Report working</li>
                <li><input type="checkbox" class="checklist-item"> Audit Log Report working</li>
                <li><input type="checkbox" class="checklist-item"> CSV export working for all reports</li>
                <li><input type="checkbox" class="checklist-item"> Operations Dashboard accessible (Admin only)</li>
                <li><input type="checkbox" class="checklist-item"> Smoke test checklist accessible</li>
                <li><input type="checkbox" class="checklist-item"> Health check endpoint responding (/health)</li>
                <li><input type="checkbox" class="checklist-item"> Application Insights or logging configured</li>
                <li><input type="checkbox" class="checklist-item"> Error logs captured and reviewable</li>
            </ul>
        </div>
    </div>

    <!-- Section 5: UAT Preparation -->
    <div class="card mb-3">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-clipboard-check"></i> 5. UAT Preparation</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> UAT Guide created (10 test scenarios)</li>
                <li><input type="checkbox" class="checklist-item"> Defect template created and distributed</li>
                <li><input type="checkbox" class="checklist-item"> UAT participant accounts created</li>
                <li><input type="checkbox" class="checklist-item"> Test data seeded and verified</li>
                <li><input type="checkbox" class="checklist-item"> UAT schedule communicated to all participants</li>
                <li><input type="checkbox" class="checklist-item"> Defect tracking process defined</li>
                <li><input type="checkbox" class="checklist-item"> Sign-off criteria defined (≥90% pass rate, no blocking errors)</li>
            </ul>
        </div>
    </div>

    <!-- Section 6: Training and Documentation -->
    <div class="card mb-3">
        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0"><i class="bi bi-book"></i> 6. Training and Documentation</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Training Guide created (role-specific quick-starts)</li>
                <li><input type="checkbox" class="checklist-item"> Demo Guide created (10 presenter flows)</li>
                <li><input type="checkbox" class="checklist-item"> Demo walkthrough scheduled with stakeholders</li>
                <li><input type="checkbox" class="checklist-item"> Training sessions scheduled for Admin, Admissions, Cashier roles</li>
                <li><input type="checkbox" class="checklist-item"> Quick reference card printed and distributed</li>
                <li><input type="checkbox" class="checklist-item"> Handoff documentation created</li>
                <li><input type="checkbox" class="checklist-item"> Runbooks created for common issues</li>
            </ul>
        </div>
    </div>

    <!-- Section 7: Integration and Sync (Future) -->
    <div class="card mb-3">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="bi bi-arrow-repeat"></i> 7. Integration and Sync (Future Phase)</h4>
        </div>
        <div class="card-body">
            <p class="text-muted">These items are planned for post-pilot phases:</p>
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item" disabled> PowerSchool API integration configured</li>
                <li><input type="checkbox" class="checklist-item" disabled> NetSuite API integration configured</li>
                <li><input type="checkbox" class="checklist-item" disabled> Scheduled sync jobs configured (daily at 2 AM)</li>
            </ul>
        </div>
    </div>

    <!-- Section 8: Deployment and Rollback -->
    <div class="card mb-3">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0"><i class="bi bi-cloud-upload"></i> 8. Deployment and Rollback</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Deployment runbook documented</li>
                <li><input type="checkbox" class="checklist-item"> Rollback procedure documented and tested</li>
                <li><input type="checkbox" class="checklist-item"> Database backup taken before deployment</li>
                <li><input type="checkbox" class="checklist-item"> Smoke tests passed post-deployment</li>
                <li><input type="checkbox" class="checklist-item"> Pilot environment URL communicated to users</li>
                <li><input type="checkbox" class="checklist-item"> Support contact information communicated</li>
                <li><input type="checkbox" class="checklist-item"> Maintenance window scheduled (if needed)</li>
            </ul>
        </div>
    </div>

    <!-- Section 9: Stakeholder Sign-Off -->
    <div class="card mb-3">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0"><i class="bi bi-pen"></i> 9. Stakeholder Sign-Off</h4>
        </div>
        <div class="card-body">
            <p><strong>Business Owner Sign-Off:</strong></p>
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Business requirements reviewed and approved</li>
                <li><input type="checkbox" class="checklist-item"> UAT scenarios reviewed and approved</li>
                <li><input type="checkbox" class="checklist-item"> Known limitations reviewed and accepted</li>
            </ul>
            <p><strong>Technical Lead Sign-Off:</strong></p>
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Architecture reviewed and approved</li>
                <li><input type="checkbox" class="checklist-item"> Security review completed</li>
                <li><input type="checkbox" class="checklist-item"> Performance testing completed (baseline)</li>
            </ul>
            <p><strong>IT Manager Sign-Off:</strong></p>
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> Infrastructure readiness confirmed</li>
                <li><input type="checkbox" class="checklist-item"> Monitoring and alerting configured</li>
                <li><input type="checkbox" class="checklist-item"> Support model documented and agreed</li>
            </ul>
        </div>
    </div>

    <!-- Section 10: Final Verification -->
    <div class="card mb-3">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-check-circle"></i> 10. Final Verification</h4>
        </div>
        <div class="card-body">
            <ul class="list-unstyled">
                <li><input type="checkbox" class="checklist-item"> All critical checklist items completed</li>
                <li><input type="checkbox" class="checklist-item"> UAT completed with ≥90% pass rate</li>
                <li><input type="checkbox" class="checklist-item"> No blocking defects remain</li>
                <li><input type="checkbox" class="checklist-item"> All stakeholder sign-offs obtained</li>
            </ul>
        </div>
    </div>

    <hr class="my-4" />

    <!-- Go/No-Go Decision -->
    <div class="card border-danger mb-4">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-exclamation-octagon"></i> Go / No-Go Decision</h4>
        </div>
        <div class="card-body">
            <h5>Pilot Deployment Decision Framework:</h5>
            
            <div class="alert alert-success">
                <h6><strong>GO FOR PILOT</strong></h6>
                <ul class="mb-0">
                    <li>All critical () items completed</li>
                    <li>UAT completed with ≥90% scenarios passing</li>
                    <li>No blocking defects</li>
                    <li>All stakeholder sign-offs obtained</li>
                    <li>Minor non-critical items documented with mitigation</li>
                </ul>
            </div>

            <div class="alert alert-warning">
                <h6><strong>GO WITH CAUTION</strong></h6>
                <ul class="mb-0">
                    <li>1-2 critical items pending (but actively being addressed)</li>
                    <li>UAT 80-89% pass rate with no blocking defects</li>
                    <li>Stakeholders aware and accept risk</li>
                    <li>Mitigation plan in place for pending items</li>
                </ul>
                <p class="mt-2 mb-0"><strong>Action:</strong> Proceed with pilot, monitor closely, address pending items within 1 week.</p>
            </div>

            <div class="alert alert-danger">
                <h6><strong>NO-GO (DO NOT PROCEED)</strong></h6>
                <ul class="mb-0">
                    <li>3+ critical items incomplete</li>
                    <li>UAT &lt;80% pass rate or any blocking defects</li>
                    <li>Security or compliance issues unresolved</li>
                    <li>Rollback plan not tested</li>
                </ul>
                <p class="mt-2 mb-0"><strong>Action:</strong> Address all blocking items, re-test UAT, reconvene for go/no-go decision.</p>
            </div>

            <div class="mt-3">
                <strong>Final Decision:</strong>
                <textarea class="form-control" rows="3" placeholder="Document the final go/no-go decision here..."></textarea>
            </div>

            <div class="mt-3">
                <strong>Decision Date:</strong> <input type="date" class="form-control" style="width: 200px; display: inline-block;" />
            </div>

            <div class="mt-3">
                <strong>Signed By:</strong> <input type="text" class="form-control" placeholder="Name, Title" />
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "PilotSupport")" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Back to Pilot Support
        </a>
        <a href="~/docs/PILOT_READINESS_CHECKLIST.md" class="btn btn-success" download>
            <i class="bi bi-download"></i> Download Full Checklist
        </a>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const checkboxes = document.querySelectorAll('.checklist-item:not([disabled])');
        const progressBar = document.getElementById('progress-bar');
        const progressText = document.getElementById('progress-text');
        const completedCount = document.getElementById('completed-count');
        const totalCount = document.getElementById('total-count');

        totalCount.textContent = checkboxes.length;

        function updateProgress() {
            const checkedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
            const percentage = Math.round((checkedCount / checkboxes.length) * 100);

            progressBar.style.width = percentage + '%';
            progressBar.setAttribute('aria-valuenow', percentage);
            progressText.textContent = percentage + '%';
            completedCount.textContent = checkedCount;

            // Change color based on progress
            progressBar.className = 'progress-bar';
            if (percentage >= 90) {
                progressBar.classList.add('bg-success');
            } else if (percentage >= 70) {
                progressBar.classList.add('bg-info');
            } else if (percentage >= 50) {
                progressBar.classList.add('bg-warning');
            } else {
                progressBar.classList.add('bg-danger');
            }
        }

        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateProgress);
        });

        // Initial update
        updateProgress();
    });
</script>
