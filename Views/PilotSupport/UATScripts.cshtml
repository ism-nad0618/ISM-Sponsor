    <!-- UT06 -->
    <div class="card mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#ut06" style="cursor: pointer;">
            <h4 class="mb-0">
                <i class="bi bi-chevron-down"></i> UT06: Duplicate Detection and Controlled Merge
                <span class="badge bg-danger float-end">Admin</span>
            </h4>
        </div>
        <div id="ut06" class="collapse">
            <div class="card-body">
                <p><strong>Objective:</strong> Verify duplicate sponsor detection and merge workflow.</p>
                <p><strong>Actors:</strong> Admin only</p>
                <p><strong>Demo Accounts:</strong> demo.admin@ism.edu.ph</p>
                <p><strong>Test Data:</strong> DEMO-SP001 (Global Tech Corporation) and DEMO-SP006 (Global Tech Corp) are potential duplicates</p>
                
                <h6 class="mt-3">Test Steps:</h6>
                <ol>
                    <li>Login as Admin</li>
                    <li>Navigate to <code>/Sponsors/Index</code></li>
                    <li>Search for "Global Tech"</li>
                    <li>Verify both DEMO-SP001 and DEMO-SP006 appear in results</li>
                    <li>Click "Detect Duplicates" button</li>
                    <li>Verify duplicate warning message: "Potential duplicates found"</li>
                    <li>Click "Review Duplicates" link</li>
                    <li>Select DEMO-SP001 (master record) and DEMO-SP006 (duplicate to merge)</li>
                    <li>Review side-by-side comparison of fields</li>
                    <li>Click "Merge Records"</li>
                    <li>Confirm merge action</li>
                    <li>Verify DEMO-SP006 is marked as inactive/merged</li>
                    <li>Verify DEMO-SP001 retains all data</li>
                    <li>Verify audit log shows merge action</li>
                </ol>

                <h6 class="mt-3">Expected Results:</h6>
                <ul>
                    <li>Duplicate detection algorithm identifies similar sponsor names</li>
                    <li>Side-by-side comparison shows all fields for both records</li>
                    <li>Merge action consolidates records (keeps master, marks duplicate as merged)</li>
                    <li>Audit log captures merge action with both sponsor IDs</li>
                </ul>

                <h6 class="mt-3">Pass Criteria:</h6>
                <ul>
                    <li>Duplicate detection identifies DEMO-SP001 and DEMO-SP006</li>
                    <li>Merge workflow works correctly</li>
                    <li>Master record retains all data</li>
                    <li>Duplicate record is marked as merged/inactive</li>
                    <li>Audit log shows merge action</li>
                </ul>

                <div class="mt-3">
                    <span class="badge bg-warning">Priority: High</span>
                    <span class="badge bg-warning">Estimated Time: 15 minutes</span>
                </div>
            </div>
        </div>
    </div>

