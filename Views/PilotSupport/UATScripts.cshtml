@{
    ViewData["Title"] = "UAT Scripts";
}

<div class="container mt-4">
    <h2><i class="bi bi-clipboard-check"></i> UAT Test Scripts</h2>
    <p class="lead">User Acceptance Testing scenarios (UT01-UT10) for pilot validation.</p>

    <div class="mb-3">
        <a href="@Url.Action("Index", "PilotSupport")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Pilot Support
        </a>
    </div>

    <hr />

    <div class="alert alert-info">
        <h5 class="alert-heading"><i class="bi bi-info-circle"></i> UAT Execution Guide</h5>
        <p class="mb-2">Follow these steps to execute UAT:</p>
        <ol class="mb-0">
            <li><strong>Review all 10 scenarios</strong> below to understand test coverage</li>
            <li><strong>Use demo accounts</strong> listed for each scenario (password: <code>Demo@2026!</code>)</li>
            <li><strong>Follow test steps</strong> exactly as written, noting any deviations</li>
            <li><strong>Record results</strong> using the evidence notes section</li>
            <li><strong>Log defects</strong> using the defect template if issues found</li>
            <li><strong>Sign off</strong> on each scenario after completion (Pass/Fail/Blocked)</li>
        </ol>
    </div>

    <div class="mb-3">
        <a href="~/docs/UAT_GUIDE.md" class="btn btn-success" download>
            <i class="bi bi-download"></i> Download Full UAT Guide
        </a>
        <a href="~/docs/DEFECT_TEMPLATE.md" class="btn btn-outline-danger" download>
            <i class="bi bi-download"></i> Download Defect Template
        </a>
        <a href="@Url.Action("DemoAccounts", "PilotSupport")" class="btn btn-outline-primary">
            <i class="bi bi-person-badge"></i> View Demo Accounts
        </a>
    </div>

    <hr />

    <!-- UT01 -->
    <div class="card mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#ut01" style="cursor: pointer;">
            <h4 class="mb-0">
                <i class="bi bi-chevron-down"></i> UT01: Login and Baseline Access
                <span class="badge bg-secondary float-end">All Roles</span>
            </h4>
        </div>
        <div id="ut01" class="collapse show">
            <div class="card-body">
                <p><strong>Objective:</strong> Verify each role can log in and access assigned pages.</p>
                <p><strong>Actors:</strong> Admin, Admissions, Cashier, Sponsor</p>
                <p><strong>Demo Accounts:</strong> demo.admin@ism.edu.ph, demo.admissions@ism.edu.ph, demo.cashier@ism.edu.ph, demo.sponsor@ism.edu.ph</p>
                
                <h6 class="mt-3">Test Steps:</h6>
                <ol>
                    <li>Navigate to <code>/Account/Login</code></li>
                    <li>Enter username (e.g., <code>demo.admin@ism.edu.ph</code>) and password (<code>Demo@2026!</code>)</li>
                    <li>Click "Login"</li>
                    <li>Verify redirect to Dashboard after successful login</li>
                    <li>Verify navigation menu shows role-appropriate links</li>
                    <li>Logout and repeat for other roles</li>
                </ol>

                <h6 class="mt-3">Expected Results:</h6>
                <ul>
                    <li><strong>Admin:</strong> See Sponsors, Dashboard, Reports, Logs, Settings, Operations</li>
                    <li><strong>Admissions:</strong> See Sponsors, Dashboard (limited), Reports (limited), no Settings</li>
                    <li><strong>Cashier:</strong> See Sponsors (read-only), Dashboard (read-only), no edit actions</li>
                    <li><strong>Sponsor:</strong> See Portal menu (future phase), limited access</li>
                    <li>All roles: No access denied errors for allowed pages</li>
                </ul>

                <h6 class="mt-3">Pass Criteria:</h6>
                <ul>
                    <li>All 4 roles can log in successfully</li>
                    <li>Navigation menus match role permissions</li>
                    <li>No unexpected errors or access denied messages</li>
                </ul>

                <div class="mt-3">
                    <span class="badge bg-info">Priority: Critical</span>
                    <span class="badge bg-warning">Estimated Time: 10 minutes</span>
                </div>
            </div>
        </div>
    </div>

    <!-- UT02 -->
    <div class="card mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#ut02" style="cursor: pointer;">
            <h4 class="mb-0">
                <i class="bi bi-chevron-down"></i> UT02: RBAC Enforcement
                <span class="badge bg-warning float-end">Admissions, Cashier</span>
            </h4>
        </div>
        <div id="ut02" class="collapse">
            <div class="card-body">
                <p><strong>Objective:</strong> Verify role-based access control (RBAC) prevents unauthorized actions.</p>
                <p><strong>Actors:</strong> Admissions (can submit requests, cannot approve), Cashier (read-only)</p>
                <p><strong>Demo Accounts:</strong> demo.admissions@ism.edu.ph, demo.cashier@ism.edu.ph</p>
                
                <h6 class="mt-3">Test Steps:</h6>
                <ol>
                    <li>Login as <strong>Admissions</strong> user</li>
                    <li>Navigate to <code>/Sponsors/Index</code></li>
                    <li>Verify "Create New Sponsor" button is visible</li>
                    <li>Search for DEMO-SP001 and click "Edit"</li>
                    <li>Make a change (e.g., billing address) and submit</li>
                    <li>Verify change request is created (not directly applied)</li>
                    <li>Logout, login as <strong>Cashier</strong></li>
                    <li>Navigate to <code>/Sponsors/Index</code></li>
                    <li>Verify "Create New Sponsor" button is NOT visible</li>
                    <li>Search for DEMO-SP001 and verify no "Edit" or "Delete" buttons</li>
                    <li>Attempt direct URL navigation to <code>/Sponsors/Edit?id=DEMO-SP001</code></li>
                    <li>Verify "Access Denied" error is shown</li>
                </ol>

                <h6 class="mt-3">Expected Results:</h6>
                <ul>
                    <li><strong>Admissions:</strong> Can create sponsors, submit change requests, cannot approve or delete</li>
                    <li><strong>Cashier:</strong> Read-only access, no create/edit/delete buttons, direct URL access blocked</li>
                    <li>All unauthorized attempts result in "Access Denied" error</li>
                </ul>

                <h6 class="mt-3">Pass Criteria:</h6>
                <ul>
                    <li>Admissions can submit change requests but cannot approve</li>
                    <li>Cashier cannot access any edit/create/delete actions</li>
                    <li>Direct URL attempts to unauthorized pages return 403 Forbidden</li>
                </ul>

                <div class="mt-3">
                    <span class="badge bg-danger">Priority: Critical</span>
                    <span class="badge bg-warning">Estimated Time: 15 minutes</span>
                </div>
            </div>
        </div>
    </div>

    <!-- UT03 -->
    <div class="card mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#ut03" style="cursor: pointer;">
            <h4 class="mb-0">
                <i class="bi bi-chevron-down"></i> UT03: Create Sponsor Record
                <span class="badge bg-danger float-end">Admin</span>
            </h4>
        </div>
        <div id="ut03" class="collapse">
            <div class="card-body">
                <p><strong>Objective:</strong> Verify sponsor creation with all required fields and validation.</p>
                <p><strong>Actors:</strong> Admin or Admissions</p>
                <p><strong>Demo Accounts:</strong> demo.admin@ism.edu.ph</p>
                
                <h6 class="mt-3">Test Steps:</h6>
                <ol>
                    <li>Login as Admin</li>
                    <li>Navigate to <code>/Sponsors/Index</code></li>
                    <li>Click "Create New Sponsor"</li>
                    <li>Fill in all required fields:
                        <ul>
                            <li>Organization Name: "Test Sponsor Organization"</li>
                            <li>Sponsor Type: Select "Corporate"</li>
                            <li>Primary Contact Name: "John Doe"</li>
                            <li>Primary Contact Email: "john.doe@testsponsor.com"</li>
                            <li>Primary Contact Phone: "+63 2 8123 4567"</li>
                            <li>Billing Address: "123 Test St, Manila, Philippines"</li>
                        </ul>
                    </li>
                    <li>Click "Create"</li>
                    <li>Verify successful creation message</li>
                    <li>Verify redirect to sponsor profile page</li>
                    <li>Verify all entered data is displayed correctly</li>
                    <li>Verify Sponsor ID is auto-generated (format: SP-YYYYMMDD-XXXX)</li>
                </ol>

                <h6 class="mt-3">Expected Results:</h6>
                <ul>
                    <li>Sponsor is created successfully with auto-generated ID</li>
                    <li>All entered data is saved correctly</li>
                    <li>Success message is displayed</li>
                    <li>User is redirected to sponsor profile page</li>
                    <li>Audit log entry is created for sponsor creation</li>
                </ul>

                <h6 class="mt-3">Pass Criteria:</h6>
                <ul>
                    <li>Sponsor record created with all fields populated</li>
                    <li>Auto-generated ID follows expected format</li>
                    <li>Success message and redirect work correctly</li>
                    <li>Audit log shows "Sponsor Created" entry</li>
                </ul>

                <div class="mt-3">
                    <span class="badge bg-danger">Priority: Critical</span>
                    <span class="badge bg-warning">Estimated Time: 10 minutes</span>
                </div>
            </div>
        </div>
    </div>

    <!-- UT04 -->
    <div class="card mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#ut04" style="cursor: pointer;">
            <h4 class="mb-0">
                <i class="bi bi-chevron-down"></i> UT04: Validation and Error Messaging
                <span class="badge bg-danger float-end">Admin</span>
            </h4>
        </div>
        <div id="ut04" class="collapse">
            <div class="card-body">
                <p><strong>Objective:</strong> Verify validation rules and error messages for sponsor creation.</p>
                <p><strong>Actors:</strong> Admin or Admissions</p>
                <p><strong>Demo Accounts:</strong> demo.admin@ism.edu.ph</p>
                
                <h6 class="mt-3">Test Steps:</h6>
                <ol>
                    <li>Login as Admin</li>
                    <li>Navigate to <code>/Sponsors/Index</code></li>
                    <li>Click "Create New Sponsor"</li>
                    <li><strong>Test 1: Required fields</strong>
                        <ul>
                            <li>Leave Organization Name blank, click "Create"</li>
                            <li>Verify error message: "Organization Name is required"</li>
                        </ul>
                    </li>
                    <li><strong>Test 2: Email format</strong>
                        <ul>
                            <li>Enter invalid email: "invalid-email"</li>
                            <li>Click "Create"</li>
                            <li>Verify error message: "Invalid email format"</li>
                        </ul>
                    </li>
                    <li><strong>Test 3: Phone format</strong>
                        <ul>
                            <li>Enter invalid phone: "abc123"</li>
                            <li>Click "Create"</li>
                            <li>Verify error message: "Invalid phone number format"</li>
                        </ul>
                    </li>
                    <li><strong>Test 4: Duplicate detection</strong>
                        <ul>
                            <li>Enter Organization Name: "Global Tech Corporation" (existing DEMO-SP001)</li>
                            <li>Click "Create"</li>
                            <li>Verify warning message: "Potential duplicate sponsor found"</li>
                        </ul>
                    </li>
                </ol>

                <h6 class="mt-3">Expected Results:</h6>
                <ul>
                    <li>Validation errors are shown inline near the field</li>
                    <li>Error messages are clear and actionable</li>
                    <li>Form is not submitted until all validations pass</li>
                    <li>Duplicate detection warning is shown (but does not block creation)</li>
                </ul>

                <h6 class="mt-3">Pass Criteria:</h6>
                <ul>
                    <li>All validation rules are enforced</li>
                    <li>Error messages are clear and user-friendly</li>
                    <li>Form submission is blocked until validations pass</li>
                    <li>Duplicate detection works correctly</li>
                </ul>

                <div class="mt-3">
                    <span class="badge bg-danger">Priority: Critical</span>
                    <span class="badge bg-warning">Estimated Time: 15 minutes</span>
                </div>
            </div>
        </div>
    </div>

    <!-- UT05 -->
    <div class="card mb-3">
        <div class="card-header" data-bs-toggle="collapse" data-bs-target="#ut05" style="cursor: pointer;">
            <h4 class="mb-0">
                <i class="bi bi-chevron-down"></i> UT05: Update Sponsor Record
                <span class="badge bg-danger float-end">Admin</span>
            </h4>
