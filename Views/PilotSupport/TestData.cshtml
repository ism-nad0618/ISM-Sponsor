    <!-- Re-seeding Instructions -->
    <div class="card mb-4 border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Re-seeding Demo Data</h4>
        </div>
        <div class="card-body">
            <p><strong>If demo data becomes corrupted or needs to be reset:</strong></p>
            <ol>
                <li>Stop the application</li>
                <li>Delete all records with <code>DEMO-</code> prefix from the database manually, or drop/recreate the database</li>
                <li>Restart the application - demo data seeder will automatically run on startup (in Development/Staging environments)</li>
                <li>Verify demo data by checking this page or the database directly</li>
            </ol>
            <p class="mb-0 text-danger">
                <strong>Warning:</strong> Re-seeding will delete all existing DEMO- records. Do not re-seed if you have UAT test results tied to these records.
            </p>
        </div>
    </div>

