@{
    ViewData["Title"] = "Documentation";
}

<div class="container mt-4">
    <h2><i class="bi bi-book"></i> Pilot Documentation Hub</h2>
    <p class="lead">Access all training guides, demo scripts, handoff docs, and technical documentation.</p>

    <div class="mb-3">
        <a href="@Url.Action("Index", "PilotSupport")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Pilot Support
        </a>
    </div>

    <hr />

    <div class="alert alert-info">
        <h5 class="alert-heading"><i class="bi bi-info-circle"></i> Documentation Overview</h5>
        <p class="mb-0">
            All documentation is available in the <code>docs/</code> folder of the project repository.
            Download links below provide direct access to each file.
        </p>
    </div>

    <!-- UAT and Testing Documentation -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-clipboard-check"></i> UAT and Testing Documentation</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-3 border-primary">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-file-earmark-text"></i> UAT Guide</h5>
                            <p class="card-text">Comprehensive UAT guide with 10 test scenarios (UT01-UT10), test execution instructions, defect logging procedures, and sign-off process.</p>
                            <p class="text-muted"><strong>Audience:</strong> UAT participants (Admin, Admissions, Cashier roles)</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/UAT_GUIDE.md</code></p>
                            <a href="~/docs/UAT_GUIDE.md" class="btn btn-primary" download><i class="bi bi-download"></i> Download</a>
                            <a href="@Url.Action("UATScripts", "PilotSupport")" class="btn btn-outline-primary">View Online</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3 border-danger">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-bug"></i> Defect Reporting Template</h5>
                            <p class="card-text">Structured defect report template with severity levels, impact assessment, resolution tracking, and retest procedures.</p>
                            <p class="text-muted"><strong>Audience:</strong> UAT participants, QA team</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/DEFECT_TEMPLATE.md</code></p>
                            <a href="~/docs/DEFECT_TEMPLATE.md" class="btn btn-danger" download><i class="bi bi-download"></i> Download</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-3 border-info">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-list-check"></i> Pilot Readiness Checklist</h5>
                            <p class="card-text">100+ item checklist covering infrastructure, security, functionality, UAT, training, deployment, and stakeholder sign-off.</p>
                            <p class="text-muted"><strong>Audience:</strong> Project team, stakeholders</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/PILOT_READINESS_CHECKLIST.md</code></p>
                            <a href="~/docs/PILOT_READINESS_CHECKLIST.md" class="btn btn-info" download><i class="bi bi-download"></i> Download</a>
                            <a href="@Url.Action("PilotChecklist", "PilotSupport")" class="btn btn-outline-info">View Online</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3 border-secondary">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-database"></i> Sample Test Data</h5>
                            <p class="card-text">Complete reference for all demo data entities (6 sponsors, 8 students, 5 LoGs, 4 change requests, demo users).</p>
                            <p class="text-muted"><strong>Audience:</strong> UAT participants, trainers</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/SAMPLE_TEST_DATA.md</code></p>
                            <a href="~/docs/SAMPLE_TEST_DATA.md" class="btn btn-secondary" download><i class="bi bi-download"></i> Download</a>
                            <a href="@Url.Action("TestData", "PilotSupport")" class="btn btn-outline-secondary">View Online</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Training and Demo Documentation -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0"><i class="bi bi-mortarboard"></i> Training and Demo Documentation</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-3 border-success">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-easel"></i> Demo Guide</h5>
                            <p class="card-text">Presenter scripts for 10 demo flows with talking points, Q&A preparation, and demo tips.</p>
                            <p class="text-muted"><strong>Audience:</strong> Demo presenters, stakeholders</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/DEMO_GUIDE.md</code></p>
                            <a href="~/docs/DEMO_GUIDE.md" class="btn btn-success" download><i class="bi bi-download"></i> Download</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3 border-warning">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-person-video3"></i> Training Guide</h5>
                            <p class="card-text">Role-specific quick-starts, 11 detailed workflows, common mistakes and recovery, quick reference card.</p>
                            <p class="text-muted"><strong>Audience:</strong> End users (Admin, Admissions, Cashier, Sponsor)</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/TRAINING_GUIDE.md</code></p>
                            <a href="~/docs/TRAINING_GUIDE.md" class="btn btn-warning" download><i class="bi bi-download"></i> Download</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Handoff and Technical Documentation -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-file-earmark-arrow-down"></i> Handoff and Technical Documentation</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-3 border-info">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-briefcase"></i> Handoff Documentation</h5>
                            <p class="card-text">Business, technical, and operational handoff with solution overview, architecture, deployment, monitoring, and support model.</p>
                            <p class="text-muted"><strong>Audience:</strong> Business owners, technical leads, IT managers</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/HANDOFF.md</code></p>
                            <a href="~/docs/HANDOFF.md" class="btn btn-info" download><i class="bi bi-download"></i> Download</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card mb-3 border-warning">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-exclamation-triangle"></i> Limitations and Future Work</h5>
                            <p class="card-text">15 known limitations with mitigation, future work backlog (20 items in 4 priority tiers), post-pilot roadmap.</p>
                            <p class="text-muted"><strong>Audience:</strong> Business owners, project managers, technical leads</p>
                            <p class="text-muted"><strong>File:</strong> <code>docs/LIMITATIONS_AND_FUTURE_WORK.md</code></p>
                            <a href="~/docs/LIMITATIONS_AND_FUTURE_WORK.md" class="btn btn-warning" download><i class="bi bi-download"></i> Download</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Operational Documentation -->
    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="bi bi-wrench"></i> Operational Documentation</h4>
        </div>
        <div class="card-body">
            <p>Operational documentation is available within the application:</p>
            <div class="row">
                <div class="col-md-4">
                    <div class="card mb-3 border-dark">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-speedometer2"></i> Operations Dashboard</h5>
                            <p class="card-text">System health monitoring with key metrics, recent activity, and alerts.</p>
                            <a href="/Operations/Dashboard" class="btn btn-dark">View Dashboard</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card mb-3 border-dark">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-check-square"></i> Smoke Test Checklist</h5>
                            <p class="card-text">Post-deployment verification checklist for quick system health check.</p>
                            <a href="/Operations/SmokeTest" class="btn btn-dark">View Smoke Test</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card mb-3 border-dark">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-book-half"></i> Operational Runbooks</h5>
                            <p class="card-text">Common issue resolution guides (Database Connection Failed, Sync Failure, etc.).</p>
                            <a href="/Operations/Runbooks" class="btn btn-dark">View Runbooks</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Resources -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h4 class="mb-0"><i class="bi bi-link-45deg"></i> Additional Resources</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="bi bi-github"></i> Source Code Repository</h5>
                    <p>Access the full source code, commit history, and project documentation on GitHub.</p>
                    <a href="#" class="btn btn-outline-secondary" disabled><i class="bi bi-github"></i> GitHub Repository (TBD)</a>
                </div>
                <div class="col-md-6">
                    <h5><i class="bi bi-envelope"></i> Support Contacts</h5>
                    <p>For technical issues during pilot, contact the support team:</p>
                    <ul>
                        <li><strong>Technical Support:</strong> itsupport@ism.edu.ph</li>
                        <li><strong>Business Owner:</strong> TBD</li>
                        <li><strong>Technical Lead:</strong> TBD</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Documentation Map -->
    <div class="card mb-4 border-info">
        <div class="card-header bg-light">
            <h4 class="mb-0"><i class="bi bi-map"></i> Documentation Map (Recommended Reading Order)</h4>
        </div>
        <div class="card-body">
            <h5>For Business Stakeholders:</h5>
            <ol>
                <li><strong>HANDOFF.md</strong> - Start here for solution overview</li>
                <li><strong>DEMO_GUIDE.md</strong> - Understand system capabilities through demo flows</li>
                <li><strong>LIMITATIONS_AND_FUTURE_WORK.md</strong> - Understand constraints and roadmap</li>
                <li><strong>PILOT_READINESS_CHECKLIST.md</strong> - Review pilot readiness status</li>
            </ol>

            <h5>For UAT Participants:</h5>
            <ol>
                <li><strong>TRAINING_GUIDE.md</strong> - Learn your role's workflows</li>
                <li><strong>SAMPLE_TEST_DATA.md</strong> - Familiarize with demo data</li>
                <li><strong>UAT_GUIDE.md</strong> - Execute test scenarios</li>
                <li><strong>DEFECT_TEMPLATE.md</strong> - Report issues during UAT</li>
            </ol>

            <h5>For Demo Presenters:</h5>
            <ol>
                <li><strong>DEMO_GUIDE.md</strong> - Master all 10 demo flows</li>
                <li><strong>SAMPLE_TEST_DATA.md</strong> - Know your demo accounts and entities</li>
                <li><strong>LIMITATIONS_AND_FUTURE_WORK.md</strong> - Be ready to answer "what's next?" questions</li>
            </ol>

            <h5>For Technical Team:</h5>
            <ol>
                <li><strong>HANDOFF.md</strong> - Understand architecture and technical design</li>
                <li><strong>Operations Dashboard</strong> - Monitor system health</li>
                <li><strong>Operational Runbooks</strong> - Resolve common issues</li>
                <li><strong>PILOT_READINESS_CHECKLIST.md</strong> - Verify technical readiness</li>
            </ol>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "PilotSupport")" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Back to Pilot Support
        </a>
    </div>
</div>
