@model ISMSponsor.ViewModels.CreateUserViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create New User";
}

<div class="page-header">
    <h1>Create New User</h1>
    <p class="page-subtitle">Add a new user account to the system</p>
</div>

<div class="card card-narrow">
    <form asp-action="Create" method="post">
        <div class="form-group">
            <label asp-for="Username">Username <span class="required">*</span></label>
            <input asp-for="Username" placeholder="Enter username" />
            <span asp-validation-for="Username" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="DisplayName">Display Name <span class="required">*</span></label>
            <input asp-for="DisplayName" placeholder="Enter display name" />
            <span asp-validation-for="DisplayName" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password">Password <span class="required">*</span></label>
            <input asp-for="Password" type="password" placeholder="Enter password" />
            <span asp-validation-for="Password" class="form-error"></span>
            <p class="help-text">Minimum 1 character</p>
        </div>

        <div class="form-group">
            <label asp-for="Role">Role <span class="required">*</span></label>
            <select asp-for="Role">
                <option value="">-- Select a role --</option>
                <option value="admin">Admin</option>
                <option value="admissions">Admissions</option>
                <option value="cashier">Cashier</option>
                <option value="sponsor">Sponsor</option>
            </select>
            <span asp-validation-for="Role" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="SponsorId">Sponsor ID <span class="optional">(optional, if role is sponsor)</span></label>
            <input asp-for="SponsorId" placeholder="e.g., ACME" />
            <span asp-validation-for="SponsorId" class="form-error"></span>
        </div>

        <div class="form-actions form-actions-bordered">
            <button type="submit" class="btn-primary">✓ Create User</button>
            <a href="@Url.Action("Index")" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
