@model List<ISMSponsor.Models.ApplicationUser>
@inject Microsoft.AspNetCore.Identity.UserManager<ISMSponsor.Models.ApplicationUser> UserManager
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <h1>User Management</h1>
    <p class="page-subtitle">Manage system users and their access levels.</p>
</div>

<div class="card">
    <div class="page-header-actions">
        <h2 class="table-title">Users Directory</h2>
        <a href="@Url.Action("Create")" class="btn-primary btn-add">+ New User</a>
    </div>
    <div class="table-wrap">
        <table>
        <thead>
            <tr>
                <th>Username</th>
                <th>Display Name</th>
                <th>Sponsor</th>
                <th>Roles</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var u in Model){
                <tr>
                    <td><strong>@u.UserName</strong></td>
                    <td>@u.DisplayName</td>
                    <td>@(u.SponsorId ?? "-")</td>
                    <td>
                        @{
                            var roles = (await UserManager.GetRolesAsync(u)).ToList();
                            if(roles.Any()){
                                @foreach(var role in roles){
                                    <span class="role-badge">@role</span>
                                }
                            }else{
                                <span class="text-muted">No roles assigned</span>
                            }
                        }
                    </td>
                    <td>
                        <span class="status-badge @(u.IsActive ? "status-active" : "status-inactive")">@(u.IsActive ? "Active" : "Inactive")</span>
                    </td>
                    <td class="text-center">
                        <a href="#" class="link-edit">Edit</a>
                        <a href="#" class="link-delete" onclick="return confirm('Are you sure?');">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>
