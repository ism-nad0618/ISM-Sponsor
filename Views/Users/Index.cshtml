@model List<ISMSponsor.Models.ApplicationUser>
@inject Microsoft.AspNetCore.Identity.UserManager<ISMSponsor.Models.ApplicationUser> UserManager
@{
    Layout = "_Layout";
    ViewData["Title"] = "User Management";
}

<div style="margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1>User Management</h1>
        <p class="text-muted">Manage system users and their roles</p>
    </div>
    <a href="@Url.Action("Create")" style="background-color: #10b981; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 14px; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#059669'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 4px 12px rgba(16, 185, 129, 0.3)';" onmouseout="this.style.backgroundColor='#10b981'; this.style.transform='none'; this.style.boxShadow='none';">+ New User</a>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th>Username</th>
                <th>Display Name</th>
                <th>Sponsor</th>
                <th>Roles</th>
                <th>Status</th>
                <th style="text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var u in Model){
                <tr>
                    <td><strong>@u.UserName</strong></td>
                    <td>@u.DisplayName</td>
                    <td>@(u.SponsorId ?? "-")</td>
                    <td>
                        @{
                            var roles = (await UserManager.GetRolesAsync(u)).ToList();
                            if(roles.Any()){
                                @foreach(var role in roles){
                                    <span style="background-color: #dbeafe; color: #1e40af; padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; margin-right: 4px; display: inline-block;">@role</span>
                                }
                            }else{
                                <span class="text-muted" style="font-style: italic;">No roles assigned</span>
                            }
                        }
                    </td>
                    <td>
                        <span style="background-color: @(u.IsActive ? "#d1fae5" : "#fee2e2"); color: @(u.IsActive ? "#065f46" : "#991b1b"); padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600;">@(u.IsActive ? "Active" : "Inactive")</span>
                    </td>
                    <td style="text-align: center;">
                        <a href="#" style="color: #2563eb; text-decoration: none; font-weight: 500; font-size: 12px; margin-right: 8px;">Edit</a>
                        <a href="#" style="color: #ef4444; text-decoration: none; font-weight: 500; font-size: 12px;" onclick="return confirm('Are you sure?');">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
