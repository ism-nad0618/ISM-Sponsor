@model ISMSponsor.ViewModels.SubmitFeedbackViewModel
@{
    ViewData["Title"] = "Submit Feedback";
}

<div class="container mt-4">
    <h2>Submit Feedback</h2>
    <p class="text-muted">Your feedback helps us improve the ISM Sponsor Management System. Thank you for taking the time to share your thoughts!</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <form method="post" asp-action="Submit" asp-controller="Feedback">
                <div class="card">
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">Category <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                <option value="WorkflowClarity">Workflow Clarity</option>
                                <option value="ValidationMessages">Validation Messages</option>
                                <option value="MissingFields">Missing Fields/Features</option>
                                <option value="Reporting">Reporting</option>
                                <option value="IntegrationReliability">Integration Reliability</option>
                                <option value="Performance">Performance</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Severity" class="form-label">Severity <span class="text-danger">*</span></label>
                            <select asp-for="Severity" class="form-select" required>
                                <option value="">-- Select Severity --</option>
                                <option value="Low">Low - Minor inconvenience</option>
                                <option value="Medium">Medium - Workflow impacted but workaround exists</option>
                                <option value="High">High - Blocking work or incorrect results</option>
                                <option value="Critical">Critical - System down or data integrity issue</option>
                            </select>
                            <span asp-validation-for="Severity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Module" class="form-label">Module <span class="text-danger">*</span></label>
                            <select asp-for="Module" class="form-select" required>
                                <option value="">-- Select Module --</option>
                                <option value="Sponsors">Sponsors</option>
                                <option value="LoG">Letters of Guarantee</option>
                                <option value="Coverage">Coverage Evaluation</option>
                                <option value="Reports">Reports</option>
                                <option value="Sync">Sync/Integration</option>
                                <option value="Dashboard">Dashboard</option>
                                <option value="Settings">Settings</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Module" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" placeholder="Brief summary of the issue or suggestion" required maxlength="200" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="6" placeholder="Please provide detailed information:&#10;- What were you trying to do?&#10;- What happened (or didn't happen)?&#10;- What did you expect?&#10;- Steps to reproduce (if applicable)" required maxlength="1000"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                            <small class="form-text text-muted">Max 1000 characters</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AffectedResource" class="form-label">Affected Resource (Optional)</label>
                            <input asp-for="AffectedResource" class="form-control" placeholder="e.g., Sponsor ID, Student ID, Report name, etc." maxlength="200" />
                            <span asp-validation-for="AffectedResource" class="text-danger"></span>
                            <small class="form-text text-muted">If applicable, provide the specific resource (sponsor, student, report) that was affected</small>
                        </div>
                    </div>

                    <div class="card-footer">
                        <button type="submit" class="btn btn-primary">Submit Feedback</button>
                        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-secondary">Cancel</a>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Feedback Guidelines</h6>
                </div>
                <div class="card-body">
                    <h6>What to report:</h6>
                    <ul class="small">
                        <li>Unclear workflows or confusing UI</li>
                        <li>Validation messages that aren't helpful</li>
                        <li>Missing fields or features</li>
                        <li>Inaccurate or slow reports</li>
                        <li>Integration/sync failures</li>
                        <li>Performance issues</li>
                    </ul>

                    <h6 class="mt-3">Tips for good feedback:</h6>
                    <ul class="small">
                        <li>Be specific about what happened</li>
                        <li>Include steps to reproduce</li>
                        <li>Mention affected resources (IDs)</li>
                        <li>Choose accurate category and severity</li>
                        <li>Suggest solutions if you have ideas</li>
                    </ul>

                    <h6 class="mt-3">What happens next:</h6>
                    <p class="small">
                        Your feedback will be reviewed by the development team. High and Critical severity items are prioritized.
                        You'll be notified of the resolution status.
                    </p>
                </div>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="card mt-3">
                    <div class="card-body">
                        <h6>Admin</h6>
                        <a href="@Url.Action("List", "Feedback")" class="btn btn-sm btn-outline-primary">View All Feedback</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
