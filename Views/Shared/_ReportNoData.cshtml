@{
    var message = ViewBag.NoDataMessage as string ?? "No data found matching your criteria.";
    var suggestions = ViewBag.Suggestions as string[] ?? new[]
    {
        "Try adjusting your filter criteria",
        "Select a different date range",
        "Check if data exists for the selected school year",
        "Clear all filters to see all available data"
    };
}

<div class="card" style="text-align: center; padding: 3rem 1rem;">
    <div style="font-size: 4rem; opacity: 0.3; margin-bottom: 1rem;"></div>
    <h2 style="margin: 0 0 0.5rem 0; color: #666;">@message</h2>
    <p style="color: #999; margin: 0 0 1.5rem 0;">Try the following to get results:</p>
    
    <ul style="list-style: none; padding: 0; margin: 0 auto; max-width: 400px; text-align: left;">
        @foreach (var suggestion in suggestions)
        {
            <li style="padding: 0.5rem 0 0.5rem 1.5rem; position: relative; color: #666;">
                <span style="position: absolute; left: 0;"></span>
                @suggestion
            </li>
        }
    </ul>
    
    <div style="margin-top: 2rem;">
        <a href="@Url.Action("Index", "Reports")" class="btn btn-primary">← Back to Reports Hub</a>
    </div>
</div>
