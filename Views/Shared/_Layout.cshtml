@using Microsoft.AspNetCore.Identity
@inject SignInManager<ISMSponsor.Models.ApplicationUser> SignInManager
@inject UserManager<ISMSponsor.Models.ApplicationUser> UserManager
@{
    var user = UserManager.GetUserAsync(User).Result;
    string role = user != null ? string.Join(", ", UserManager.GetRolesAsync(user).Result) : "";
    string display = user?.DisplayName ?? User.Identity?.Name ?? "User";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    Func<string, string, string> navClass = (controller, action) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
        (string.IsNullOrEmpty(action) || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            ? "active"
            : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <meta name="description" content="ISM Sponsor Portal - Manage Letters of Guarantee and student sponsorships" />
    <meta name="theme-color" content="#0d5f3b" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="ISM Sponsor" />
    <title>@ViewData["Title"] - ISM Sponsor Portal</title>
    <link rel="icon" type="image/png" sizes="192x192" href="~/icons/icon-192.png" />
    <link rel="shortcut icon" href="~/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.png" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/js/site.js"></script>
</head>
<body>
    <div class="top-bar">
        <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle navigation menu" aria-expanded="false">
            <span class="hamburger-icon"></span>
        </button>
        
        <div class="logo">
            <div class="logo-main">INTERNATIONAL SCHOOL MANILA</div>
            <div class="logo-sub">Sponsor Portal</div>
        </div>

        <div class="user-info">
            @if (SignInManager.IsSignedIn(User))
            {
                <span class="user-display-name">@display</span>
                <span class="user-role">(@role)</span>
                <form method="post" asp-controller="Account" asp-action="Logout">
                    <button type="submit" class="btn-logout">Sign Out</button>
                </form>
            }
        </div>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>
    
    <nav class="sidebar" id="sidebar" role="navigation" aria-label="Main navigation" aria-hidden="true">
        <button class="sidebar-close" id="sidebarClose" aria-label="Close navigation menu">
            <span aria-hidden="true">&times;</span>
        </button>
        
        <ul>
            <li><a class="@navClass("Dashboard", "Index")" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
            
            @if (User.IsInRole("sponsor"))
            {
                <li><a class="@navClass("Portal", "LettersOfGuarantee")" asp-controller="Portal" asp-action="LettersOfGuarantee">Letters of Guarantee</a></li>
                <li><a class="@navClass("Portal", "Students")" asp-controller="Portal" asp-action="Students">Students</a></li>
                <li><a class="@navClass("Portal", "Requests")" asp-controller="Portal" asp-action="Requests">Change Requests</a></li>
                <li><a class="@navClass("Portal", "Contacts")" asp-controller="Portal" asp-action="Contacts">Contacts</a></li>
                <li><a class="@navClass("Sponsors", "Profile")" asp-controller="Sponsors" asp-action="Profile">My Profile</a></li>
            }
            
            @if (User.IsInRole("admin") || User.IsInRole("cashier"))
            {
                <li><a class="@navClass("Sponsors", "Index")" asp-controller="Sponsors" asp-action="Index">All Sponsors</a></li>
                <li><a class="@navClass("AdminReports", "AllContacts")" asp-controller="AdminReports" asp-action="AllContacts">All Contacts</a></li>
            }
            @if (User.IsInRole("admin") || User.IsInRole("admissions") || User.IsInRole("cashier"))
            {
                <li><a class="@navClass("LetterOfGuarantee", "")" asp-controller="LetterOfGuarantee" asp-action="Index">Letters of Guarantee</a></li>
            }
            
            <li><a class="@navClass("Reports", "Index")" asp-controller="Reports" asp-action="Index">Reports</a></li>

            @if (User.IsInRole("admin"))
            {
                <li><strong>Settings</strong></li>
                <li><a class="@navClass("SchoolYears", "Index")" asp-controller="SchoolYears" asp-action="Index">School Years</a></li>
                <li><a class="@navClass("Students", "Index")" asp-controller="Students" asp-action="Index">Students</a></li>
                <li><a class="@navClass("Items", "Index")" asp-controller="Items" asp-action="Index">Items</a></li>
                <li><a class="@navClass("Roles", "Index")" asp-controller="Roles" asp-action="Index">Roles</a></li>
                <li><a class="@navClass("Users", "Index")" asp-controller="Users" asp-action="Index">Users</a></li>
            }
        </ul>
    </nav>

    <main class="main-content" role="main">
        @RenderBody()
    </main>

    @* Toast Notification System *@
    @await Html.PartialAsync("_Toast")

    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Unregister any existing service workers
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(function(registrations) {
                for(let registration of registrations) {
                    registration.unregister();
                }
            });
        }
    </script>
</body>
</html>
