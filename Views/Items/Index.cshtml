@model List<ISMSponsor.Models.Domain.Item>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Items";
}

<div class="page-header">
    <h1>Items Management</h1>
    <p class="page-subtitle">Manage required items by grade level</p>
</div>

<div class="card">
    <h2 class="table-title">Items Directory</h2>
    <div class="table-wrap">
        <table>
        <thead>
            <tr>
                <th>Item ID</th>
                <th>Item Name</th>
                <th>Grade Level</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if(Model.Count == 0){
                <tr>
                    <td colspan="5" class="empty-state">No items found</td>
                </tr>
            }else{
                @foreach(var item in Model){
                    <tr>
                        <td><strong>@item.ItemId</strong></td>
                        <td>@item.ItemName</td>
                        <td><span class="grade-badge">@item.GradeLevel</span></td>
                        <td>
                            <span class="status-badge @(item.IsActive ? "status-active" : "status-inactive")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-center">
                            <a href="#" class="link-edit">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    </div>
</div>
