@model List<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Roles";
    
    // Role descriptions mapping
    var roleDescriptions = new Dictionary<string, string>
    {
        { "admin", "Full system access with administrative privileges. Can manage users, settings, and all system features." },
        { "sponsor", "Sponsor portal users. Can view and manage student Letters of Guarantee for their sponsored students." },
        { "admissions", "Admissions staff. Can view student data, manage enrollments, and generate admissions reports." },
        { "cashier", "Cashier staff. Can access billing information, process payments, and generate financial reports." },
        { "operations", "Operations staff. Can access system monitoring, logs, and operational tools for support." }
    };
}

<div class="page-header">
    <h1>Role Management</h1>
    <p class="page-subtitle">Manage system roles and permissions</p>
</div>

<div class="card">
    <h2 class="table-title">Roles Directory (@Model.Count roles)</h2>
    <div class="table-wrap">
        <table>
        <thead>
            <tr>
                <th>Role Name</th>
                <th>Description</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if(Model.Count == 0){
                <tr>
                    <td colspan="3" class="empty-state">No roles found</td>
                </tr>
            }else{
                @foreach(var role in Model){
                    var description = roleDescriptions.ContainsKey(role.Name?.ToLower() ?? "") 
                        ? roleDescriptions[role.Name.ToLower()] 
                        : "Custom role";
                    <tr data-id="@role.Id">
                        <td>
                            <span class="view-mode">
                                <span class="role-badge">
                                    @role.Name
                                </span>
                            </span>
                            <input type="text" class="edit-mode" value="@role.Name" data-field="Name" style="display:none; width: 100%;" />
                        </td>
                        <td>
                            <span style="font-size: 13px; color: var(--gray-600);">@description</span>
                        </td>
                        <td data-label="Actions" class="action-cell">
                            <div class="view-mode">
                                <a href="javascript:void(0)" class="btn-link btn-edit" data-id="@role.Id">Edit</a>
                            </div>
                            <div class="edit-mode" style="display:none;">
                                <a href="javascript:void(0)" class="btn-link btn-save" data-id="@role.Id" style="color: green;">Save</a>
                                <a href="javascript:void(0)" class="btn-link btn-cancel" data-id="@role.Id" style="color: red;">Cancel</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Edit button click
    document.querySelectorAll('.btn-edit').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.getAttribute('data-id');
            const row = document.querySelector(`tr[data-id="${id}"]`);
            
            // Hide view mode, show edit mode
            row.querySelectorAll('.view-mode').forEach(el => el.style.display = 'none');
            row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'inline-block');
        });
    });
    
    // Cancel button click
    document.querySelectorAll('.btn-cancel').forEach(btn => {
        btn.addEventListener('click', function() {
            const id = this.getAttribute('data-id');
            const row = document.querySelector(`tr[data-id="${id}"]`);
            
            // Show view mode, hide edit mode
            row.querySelectorAll('.view-mode').forEach(el => el.style.display = '');
            row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'none');
        });
    });
    
    // Save button click
    document.querySelectorAll('.btn-save').forEach(btn => {
        btn.addEventListener('click', async function() {
            const id = this.getAttribute('data-id');
            const row = document.querySelector(`tr[data-id="${id}"]`);
            
            // Collect data from input field
            const data = {
                Id: id,
                Name: row.querySelector('[data-field="Name"]').value
            };
            
            try {
                const response = await fetch('@Url.Action("EditInline")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Update view mode value
                    row.querySelector('.view-mode .badge-yellow').textContent = data.Name;
                    
                    // Hide edit mode, show view mode
                    row.querySelectorAll('.view-mode').forEach(el => el.style.display = '');
                    row.querySelectorAll('.edit-mode').forEach(el => el.style.display = 'none');
                    
                    // Show success message
                    alert(result.message);
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while saving');
            }
        });
    });
});
</script>