@model List<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Roles";
}

<div style="margin-bottom: 32px;">
    <h1>Role Management</h1>
    <p class="text-muted">Manage system roles and permissions</p>
</div>

<div class="card">
    <table>
        <thead>
            <tr>
                <th>Role Name</th>
                <th style="text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if(Model.Count == 0){
                <tr>
                    <td colspan="2" style="text-align: center; color: #9ca3af; padding: 32px;">No roles found</td>
                </tr>
            }else{
                @foreach(var role in Model){
                    <tr>
                        <td>
                            <span style="background-color: #fef3c7; color: #92400e; padding: 6px 12px; border-radius: 6px; font-weight: 600;">
                                @role.Name
                            </span>
                        </td>
                        <td style="text-align: center;">
                            <a href="#" style="color: #2563eb; text-decoration: none; font-weight: 500; font-size: 12px; margin-right: 8px;">Edit</a>
                            <a href="#" style="color: #ef4444; text-decoration: none; font-weight: 500; font-size: 12px;" onclick="return confirm('Delete this role?');">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
