@model List<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Roles";
}

<div class="page-header">
    <h1>Role Management</h1>
    <p class="page-subtitle">Manage system roles and permissions</p>
</div>

<div class="card">
    <h2 class="table-title">Roles Directory</h2>
    <div class="table-wrap">
        <table>
        <thead>
            <tr>
                <th>Role Name</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if(Model.Count == 0){
                <tr>
                    <td colspan="2" class="empty-state">No roles found</td>
                </tr>
            }else{
                @foreach(var role in Model){
                    <tr>
                        <td>
                            <span class="badge-yellow">
                                @role.Name
                            </span>
                        </td>
                        <td class="text-center">
                            <a href="#" class="link-edit">Edit</a>
                            <a href="#" class="link-delete" onclick="return confirm('Delete this role?');">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    </div>
</div>
