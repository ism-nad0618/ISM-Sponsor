@model ISMSponsor.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "ISM Sponsor Management - Sign In";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <meta name="description" content="ISM Sponsor Management System - Sign in to manage Letters of Guarantee" />
    <meta name="theme-color" content="#0d5f3b" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #f7fbf8 0%, #edf3ef 50%, #e8f2ec 100%);
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
        }

        .login-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 40px 32px;
            box-shadow: 0 4px 20px rgba(13, 95, 59, 0.08);
        }

        .school-logo {
            font-size: 14px;
            letter-spacing: 1.5px;
            font-weight: 800;
            color: #0d5f3b;
            margin: 0 0 16px 0;
            text-align: center;
            text-transform: uppercase;
        }

        .login-heading {
            font-size: 26px;
            font-weight: 700;
            color: #1a1a1a;
            margin: 0 0 12px 0;
            text-align: center;
        }

        .login-subtitle {
            font-size: 14px;
            color: #6b7280;
            margin: 0 0 32px 0;
            text-align: center;
            line-height: 1.6;
        }

        .divider {
            text-align: center;
            color: #9ca3af;
            font-size: 13px;
            margin: 24px 0;
            position: relative;
        }

        .divider::before,
        .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 42%;
            height: 1px;
            background: #e5e7eb;
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        .google-signin-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
            background: #ffffff;
            color: #1f2937;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            padding: 14px 24px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            min-height: 48px;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }

        .google-signin-btn:hover {
            background: #f9fafb;
            border-color: #d1d5db;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .google-signin-btn:active {
            transform: scale(0.98);
        }

        .google-icon {
            width: 20px;
            height: 20px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .field-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Montserrat', sans-serif;
            transition: all 0.2s ease;
            min-height: 44px;
            background: #ffffff;
        }

        input[type="text"]:focus,
        input[type="password"]:focus {
            outline: 2px solid #b7dbc7;
            border-color: #0d5f3b;
            outline-offset: 0;
        }

        .btn-signin {
            width: 100%;
            background: #0d5f3b;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            padding: 14px 24px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            min-height: 48px;
            font-family: 'Montserrat', sans-serif;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }

        .btn-signin:hover {
            background: #0a4a2d;
        }

        .btn-signin:active {
            transform: scale(0.98);
        }

        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .alert-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }

        .validation-message {
            display: block;
            margin-top: 4px;
            font-size: 12px;
            color: #dc2626;
            font-weight: 500;
        }

        /* Responsive Design */
        @@media (max-width: 767px) {
            .login-card {
                padding: 32px 24px;
            }

            .login-heading {
                font-size: 24px;
            }

            .login-subtitle {
                font-size: 13px;
            }
        }

        @@media (max-width: 479px) {
            body {
                padding: 12px;
            }

            .login-card {
                padding: 28px 20px;
            }

            .school-logo {
                font-size: 12px;
            }

            .login-heading {
                font-size: 22px;
            }

            .login-subtitle {
                font-size: 13px;
                margin-bottom: 24px;
            }
        }

        /* Print Styles */
        @@media print {
            body {
                background: white;
            }
            .login-card {
                box-shadow: none;
                border: 1px solid #000;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <h2 class="school-logo">International School Manila</h2>
            <h1 class="login-heading">Sign In</h1>
            <p class="login-subtitle">Sign in using your ISM Google account (@@ismanila.org) or your assigned Sponsor Organization username and password.</p>

            @if (Model != null && !string.IsNullOrEmpty(Model.ReturnUrl) && Model.ReturnUrl.Contains("AccessDenied"))
            {
                <div class="alert alert-error">
                    <strong>Access Denied.</strong> You do not have permission to access that page.
                </div>
            }

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
            {
                <div class="alert alert-error">
                    @(ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage ?? string.Empty)
                </div>
            }

            <!-- Google Sign-In -->
            <a href="@Url.Action("GoogleLogin", "Account", new { returnUrl = Model?.ReturnUrl })" class="google-signin-btn">
                <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Sign in with Google
            </a>

            <div class="divider">or</div>

            <!-- Sponsor Organization Login Form -->
            <form asp-action="Login" method="post">
                <div class="form-group">
                    <label class="field-label" for="Username">Username</label>
                    <input asp-for="Username" placeholder="Enter your username" />
                    <span asp-validation-for="Username" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="field-label" for="Password">Password</label>
                    <input asp-for="Password" type="password" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="validation-message"></span>
                </div>

                <input type="hidden" asp-for="ReturnUrl" />

                <button type="submit" class="btn-signin">Sign In</button>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
