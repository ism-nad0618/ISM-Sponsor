@model ISMSponsor.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "INTERNATIONAL SCHOOL MANILA - Sponsor Portal Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            display: grid;
            place-items: center;
            min-height: 100vh;
            background: linear-gradient(130deg, #f7fbf8 0%, #edf3ef 100%);
            padding: 16px;
        }

        .login-card {
            width: min(430px, 100%);
            background: #ffffff;
            border: 1px solid #dde3df;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 12px 28px rgba(12, 41, 27, 0.08);
        }

        .login-title {
            font-size: 14px;
            letter-spacing: 1px;
            font-weight: 800;
            color: #0d5f3b;
            margin: 0 0 4px;
        }

        .login-subtitle {
            color: #66726b;
            margin-bottom: 18px;
            font-size: 13px;
        }

        .form-group { margin-bottom: 12px; }
    </style>
</head>
<body>
    <div class="login-card">
        <p class="login-title">INTERNATIONAL SCHOOL MANILA</p>
        <h1 style="font-size: 24px; margin-bottom: 6px;">Sponsor Portal Login</h1>
        <p class="login-subtitle">Sign in to manage Letters of Guarantee (LoGs), invoices, and sponsor records.</p>

        <form asp-action="Login" method="post">
            @if (Model != null && !string.IsNullOrEmpty(Model.ReturnUrl) && Model.ReturnUrl.Contains("AccessDenied"))
            {
                <div class="alert alert-error">
                    <strong>Access Denied.</strong> You do not have permission to access that page.
                </div>
            }

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
            {
                <div class="alert alert-error">
                    @(ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage ?? string.Empty)
                </div>
            }

            <div class="form-group">
                <label class="field-label" for="Username">Username</label>
                <input asp-for="Username" placeholder="Enter your username" />
                <span asp-validation-for="Username" class="alert alert-error" style="display: block; margin-top: 6px;"></span>
            </div>

            <div class="form-group">
                <label class="field-label" for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="alert alert-error" style="display: block; margin-top: 6px;"></span>
            </div>

            <input type="hidden" asp-for="ReturnUrl" />

            <button type="submit" style="width: 100%; margin-top: 4px;">Sign In</button>
        </form>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
