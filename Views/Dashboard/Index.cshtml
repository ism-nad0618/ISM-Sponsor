@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";

    var logs = ViewBag.Logs as List<ISMSponsor.Models.Domain.LogCoverage> ?? new List<ISMSponsor.Models.Domain.LogCoverage>();
    var selectedSchoolYear = ViewBag.SelectedSchoolYear as ISMSponsor.Models.Domain.SchoolYear;
    var activeLoGsCount = (int)(ViewBag.ActiveLoGsCount ?? 0);
    var sponsorLoGsCount = (int)(ViewBag.SponsorLoGsCount ?? 0);

    var pendingLogs = logs.Count(l => !string.Equals(l.LogStatus, "Approved", StringComparison.OrdinalIgnoreCase));
    var approvedLogs = logs.Count(l => string.Equals(l.LogStatus, "Approved", StringComparison.OrdinalIgnoreCase));
}

<div class="page-header">
    <h1>Dashboard</h1>
    <p class="page-subtitle">
        Summary for school year: <strong>@(selectedSchoolYear?.Name ?? "Not Selected")</strong>
    </p>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Active LoGs</div>
        <div class="stat-value">@(User.IsInRole("sponsor") ? sponsorLoGsCount : activeLoGsCount)</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Pending LoGs</div>
        <div class="stat-value">@pendingLogs</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Approved LoGs</div>
        <div class="stat-value">@approvedLogs</div>
    </div>
</div>

<div class="card">
    <h2 class="table-title">Recent LoGs Records (@Math.Min(logs.Count, 6) of @logs.Count)</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Student ID</th>
                    <th>Status</th>
                    <th>Last Uploaded</th>
                </tr>
            </thead>
            <tbody>
                @if (!logs.Any())
                {
                    <tr>
                        <td colspan="3">No LoGs records available.</td>
                    </tr>
                }
                else
                {
                    foreach (var log in logs.Take(6))
                    {
                        <tr>
                            <td data-label="Student ID">@log.StudentId</td>
                            <td data-label="Status">@log.LogStatus</td>
                            <td data-label="Last Uploaded">@(log.AttachmentUploadedOn?.ToShortDateString() ?? "N/A")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
