@model List<ISMSponsor.Models.Domain.Student>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Students";
}

<div class="page-header">
    <h1>Student Management</h1>
    <p class="page-subtitle">Manage student records and assignments</p>
</div>

<div class="card">
    <h2 class="table-title">Students Directory</h2>
    <div class="table-wrap">
        <table>
        <thead>
            <tr>
                <th>School Year</th>
                <th>Student ID</th>
                <th>Full Name</th>
                <th>Grade</th>
                <th>Sponsor</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if(Model.Count == 0){
                <tr>
                    <td colspan="6" class="empty-state">No students found</td>
                </tr>
            }else{
                @foreach(var s in Model){
                    <tr>
                        <td><strong>@s.SchoolYearId</strong></td>
                        <td>@s.StudentId</td>
                        <td>@s.LastName, @s.FirstName</td>
                        <td>@s.GradeLevel</td>
                        <td>@s.SponsorId</td>
                        <td>
                            <span class="status-badge @(s.StudentStatus?.ToLower() == "active" ? "status-active" : "status-inactive")">
                                @s.StudentStatus
                            </span>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    </div>
</div>
