@model IEnumerable<ISMSponsor.Models.Domain.MergeOperation>
@{
    ViewData["Title"] = "Merge History";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-history"></i> Merge History</h2>
            <p class="text-muted mb-0">View audit trail of all sponsor merge operations</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to Duplicates
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Recent Merge Operations</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Merge Date</th>
                                <th>Survivor Sponsor</th>
                                <th>Merged Sponsor ID</th>
                                <th>Reason</th>
                                <th>Students</th>
                                <th>Contacts</th>
                                <th>Performed By</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var merge in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@merge.InitiatedOn.ToString("MMM d, yyyy")</strong><br />
                                        <small class="text-muted">@merge.InitiatedOn.ToString("h:mm tt")</small>
                                    </td>
                                    <td>
                                        <a asp-controller="Sponsors" asp-action="Profile" asp-route-id="@merge.SurvivingSponsorId">
                                            @(merge.SurvivingSponsor?.SponsorName ?? "Unknown")
                                        </a>
                                        <br />
                                        <small class="text-muted">ID: @merge.SurvivingSponsorId</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@merge.MergedSponsorId</span>
                                    </td>
                                    <td>
                                        @merge.MergeReason
                                        @if (!string.IsNullOrEmpty(merge.Notes))
                                        {
                                            <br />
                                            <small class="text-muted" title="@merge.Notes">
                                                <i class="fas fa-sticky-note"></i> Has notes
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@merge.UsersReassigned</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@merge.ChildRecordsReassigned</span>
                                    </td>
                                    <td>
                                        <small>@merge.InitiatedByUserDisplay</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-@(merge.Status == "Completed" ? "success" : 
                                                               merge.Status == "Failed" ? "danger" : "warning")">
                                            @(merge.Status == "Completed" ? "" : merge.Status == "Failed" ? "" : "") @merge.Status
                                        </span>
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(merge.Notes))
                                {
                                    <tr class="table-secondary collapse" id="notes-@merge.MergeOperationId">
                                        <td colspan="8">
                                            <strong>Notes:</strong><br />
                                            @merge.Notes
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No merge operations have been performed yet.
        </div>
    }
</div>

@section Scripts {
    <script>
        // Allow expanding merge notes
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(el) {
            el.addEventListener('click', function() {
                var target = document.querySelector(this.getAttribute('data-bs-target'));
                new bootstrap.Collapse(target, {toggle: true});
            });
        });
    </script>
}
