@model ISMSponsor.ViewModels.SmokeTestViewModel
@{
    ViewData["Title"] = "Smoke Test Checklist";
}

<div class="container mt-4">
    <h2>Post-Deployment Smoke Test Checklist</h2>
    <p class="text-muted">Environment: <strong>@Model.Environment</strong> | Version: <strong>@Model.Version</strong></p>

    <div class="alert alert-info">
        <strong>Instructions:</strong> Execute each test item in order. Mark as Pass/Fail and add notes where applicable.
        This checklist helps verify critical functionality after deployment.
    </div>

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h5>Test Summary</h5>
                    <div class="row">
                        <div class="col-md-3">
                            <strong>Total Tests:</strong> @Model.TotalTests
                        </div>
                        <div class="col-md-3">
                            <strong>Passed:</strong> <span class="text-success">@Model.PassedTests</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Failed:</strong> <span class="text-danger">@Model.FailedTests</span>
                        </div>
                        <div class="col-md-3">
                            <strong>Not Run:</strong> <span class="text-secondary">@Model.NotRunTests</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @foreach (var category in Model.TestItems.GroupBy(t => t.Category))
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">@category.Key Tests</h5>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th style="width: 5%">#</th>
                            <th style="width: 25%">Test Name</th>
                            <th style="width: 40%">Description</th>
                            <th style="width: 10%">Status</th>
                            <th style="width: 20%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var test in category)
                        {
                            <tr>
                                <td>@test.TestId</td>
                                <td>@test.TestName</td>
                                <td class="small">@test.Description</td>
                                <td>
                                    @if (test.Status == "Pass")
                                    {
                                        <span class="badge bg-success"> Pass</span>
                                    }
                                    else if (test.Status == "Fail")
                                    {
                                        <span class="badge bg-danger"> Fail</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Not Run</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-success btn-sm" onclick="markTest(@test.TestId, 'Pass')">Pass</button>
                                        <button type="button" class="btn btn-danger btn-sm" onclick="markTest(@test.TestId, 'Fail')">Fail</button>
                                    </div>
                                </td>
                            </tr>

                            @if (!string.IsNullOrEmpty(test.Notes))
                            {
                                <tr class="table-light">
                                    <td></td>
                                    <td colspan="4">
                                        <small><strong>Notes:</strong> @test.Notes</small>
                                        @if (test.TestedAt.HasValue)
                                        {
                                            <br/>
                                            <small class="text-muted">Tested by @test.TestedBy on @test.TestedAt.Value.ToString("MMM dd, yyyy HH:mm")</small>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <h5>Deployment Notes</h5>
            <p class="text-muted">Document any issues or observations during smoke testing:</p>
            <textarea class="form-control" rows="5" placeholder="Add deployment notes here..."></textarea>
            <button class="btn btn-primary mt-2">Save Notes</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function markTest(testId, status) {
            const notes = prompt(`Notes for test ${testId} (optional):`);
            const evidence = prompt(`Evidence/Screenshot link (optional):`);
            
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("UpdateSmokeTestResult", "Operations")';
            
            const addField = (name, value) => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = name;
                input.value = value || '';
                form.appendChild(input);
            };
            
            addField('testId', testId);
            addField('status', status);
            addField('notes', notes);
            addField('evidence', evidence);
            addField('__RequestVerificationToken', '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1]);
            
            document.body.appendChild(form);
            form.submit();
        }
    </script>
}
