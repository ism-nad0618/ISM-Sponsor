@model List<ISMSponsor.Models.Domain.SponsorContact>
<div class="modal active" role="dialog" aria-modal="true" onclick="if (event.target === this) closeModal();">
    <div class="modal-content" onclick="event.stopPropagation();">
        <div class="modal-header">
            <h3>Sponsor Contacts</h3>
            <button type="button" class="close" onclick="closeModal()">&times;</button>
        </div>

        <h4 class="table-title">Current Contacts</h4>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3">No contacts found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var c in Model)
                        {
                            <tr>
                                <td>@c.Name</td>
                                <td>@c.Email</td>
                                <td>@c.Phone</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <h4 class="table-title mt-2">Add Contact</h4>
        <form asp-controller="Sponsors" asp-action="Contacts" method="post">
            <input type="hidden" name="SponsorId" value="@(Model?.FirstOrDefault()?.SponsorId ?? "")" />
            <div>
                <label class="field-label" for="ContactName">Contact Name</label>
                <input id="ContactName" name="ContactName" required />
            </div>
            <div>
                <label class="field-label" for="Email">Email</label>
                <input id="Email" name="Email" type="email" required />
            </div>
            <div>
                <label class="field-label" for="Phone">Phone</label>
                <input id="Phone" name="Phone" required />
            </div>
            <div class="flex-start mt-1">
                <input type="checkbox" id="IsActive" name="IsActive" checked class="w-auto" />
                <label for="IsActive">Active</label>
            </div>
            <div class="mt-2">
                <button type="submit">Save Contact</button>
            </div>
        </form>
    </div>
</div>
