@model ISMSponsor.Models.Domain.Sponsor
@{
    Layout = "_Layout";
    ViewData["Title"] = "Create New Sponsor";
}

<div class="page-header">
    <h1>Create New Sponsor</h1>
    <p class="page-subtitle">Add a new sponsor organization to the system</p>
</div>

@if (TempData["Error"] is string errorText)
{
    <div class="alert alert-error">@errorText</div>
}

<div class="card card-narrow">
    <form asp-action="Create" method="post">
        <div class="form-group">
            <label asp-for="SponsorId" class="field-label">Sponsor ID <span class="required">*</span></label>
            <input asp-for="SponsorId" placeholder="e.g., ACME" required />
            <span asp-validation-for="SponsorId" class="form-error"></span>
            <p class="help-text">Unique identifier for the sponsor</p>
        </div>

        <div class="form-group">
            <label asp-for="SponsorName" class="field-label">Sponsor Name <span class="required">*</span></label>
            <input asp-for="SponsorName" placeholder="Enter sponsor name" required />
            <span asp-validation-for="SponsorName" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="LegalName" class="field-label">Legal Name <span class="required">*</span></label>
            <input asp-for="LegalName" placeholder="Enter legal business name" required />
            <span asp-validation-for="LegalName" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Address" class="field-label">Address <span class="required">*</span></label>
            <textarea asp-for="Address" rows="3" placeholder="Enter complete address" required></textarea>
            <span asp-validation-for="Address" class="form-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Tin" class="field-label">Tax Identification Number (TIN) <span class="required">*</span></label>
            <input asp-for="Tin" placeholder="Enter TIN" required />
            <span asp-validation-for="Tin" class="form-error"></span>
        </div>

        <div class="form-actions form-actions-bordered">
            <button type="submit" class="btn-primary btn-add">✓ Create Sponsor</button>
            <a asp-action="Index" class="btn-secondary btn-add">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
