@model ISMSponsor.Models.Domain.Sponsor
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sponsor Profile";
}

<div class="page-header">
    <div class="page-header-actions">
        <div>
            <h1>Sponsor Profile</h1>
            <p class="page-subtitle">View and manage sponsor information.</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <button type="button" class="btn-primary" onclick="openContacts()">View Contacts</button>
            @if (User.IsInRole("sponsor"))
            {
                <button type="button" class="btn-primary" onclick="openRequestChange()">Request Change</button>
            }
            else
            {
                <button type="button" class="btn-primary" onclick="openChangeRequestAdmin()">Request Change</button>
            }
        </div>
    </div>
</div>

<div class="card">
    <div class="data-grid">
        <div>
            <span class="field-label">Sponsor Name</span>
            <p><strong>@Model.SponsorName</strong></p>
        </div>
        <div>
            <span class="field-label">Legal Name</span>
            <p><strong>@Model.LegalName</strong></p>
        </div>
        <div>
            <span class="field-label">Address</span>
            <p>@Model.Address</p>
        </div>
        <div>
            <span class="field-label">Tax Identification Number (TIN)</span>
            <p>@Model.Tin</p>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script>
        function openContacts() {
            fetch(`/Sponsors/Contacts?sponsorId=@Model.SponsorId`)
                .then(r => r.text())
                .then(html => {
                    document.getElementById('modalContainer').innerHTML = html;
                    document.querySelector('.modal')?.classList.add('active');
                });
        }

        function openRequestChange() {
            fetch(`/SponsorRequest/CreateModal`)
                .then(r => r.text())
                .then(html => {
                    document.getElementById('modalContainer').innerHTML = html;
                    document.querySelector('.modal')?.classList.add('active');
                })
                .catch(error => {
                    console.error('Error loading modal:', error);
                    alert('Failed to load request form. Please try again.');
                });
        }

        function openChangeRequestAdmin() {
            const html = `<div class="modal active" role="dialog" aria-modal="true" onclick="if (event.target === this) closeModal();">
                <div class="modal-content" onclick="event.stopPropagation();">
                    <div class="modal-header">
                        <h3>Request Change</h3>
                        <button type="button" class="close" onclick="closeModal()">&times;</button>
                    </div>
                    <form method="post" action="/Sponsors/RequestChange">
                        <input type="hidden" name="SponsorId" value="@Model.SponsorId" />
                        <div>
                            <label class="field-label" for="fieldSelect">Field to Change</label>
                            <select name="Field" id="fieldSelect" onchange="updateLabel()">
                                <option value="sponsorName">Sponsor Name</option>
                                <option value="legalName">Legal Name</option>
                                <option value="address">Address</option>
                                <option value="tin">TIN</option>
                            </select>
                        </div>
                        <div>
                            <label class="field-label" id="labelCurrent">Current Value</label>
                            <input type="text" name="CurrentValue" id="currentValue" readonly style="background-color: #f5f5f5;" />
                        </div>
                        <div>
                            <label class="field-label" for="newValue">New Value</label>
                            <input type="text" id="newValue" name="NewValue" required />
                        </div>
                        <div class="flex-start mt-2" style="gap: 12px;">
                            <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
                            <button type="submit" class="btn-primary">Submit Request</button>
                        </div>
                    </form>
                </div>
            </div>`;
            document.getElementById('modalContainer').innerHTML = html;
            updateLabel();
        }

        function closeModal() {
            document.getElementById('modalContainer').innerHTML = '';
        }

        function updateLabel() {
            const field = document.getElementById('fieldSelect').value;
            const values = {
                sponsorName: '@Model.SponsorName',
                legalName: '@Model.LegalName',
                address: '@Model.Address',
                tin: '@Model.Tin'
            };
            document.getElementById('currentValue').value = values[field] || '';
        }
    </script>
}
