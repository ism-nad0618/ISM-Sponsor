            const contactId = document.getElementById('editContactId').value;
            const sponsorId = document.getElementById('editContactSponsorId').value;
            const name = document.getElementById('editContactName').value.trim();
            const email = document.getElementById('editContactEmail').value.trim();
            const phone = document.getElementById('editContactPhone').value.trim();
            
            // Validation
            let hasError = false;
            if (!name) {
                document.getElementById('editContactName-error').textContent = 'Name is required.';
                hasError = true;
            }
            if (!email) {
                document.getElementById('editContactEmail-error').textContent = 'Email is required.';
                hasError = true;
            } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                document.getElementById('editContactEmail-error').textContent = 'Please enter a valid email address.';
                hasError = true;
            }
            if (!phone) {
                document.getElementById('editContactPhone-error').textContent = 'Phone is required.';
                hasError = true;
            }
            
            if (hasError) {
                return;
            }
            
            const updateBtn = document.getElementById('updateContactBtn');
            const originalText = updateBtn.innerHTML;
            updateBtn.disabled = true;
            updateBtn.innerHTML = 'Updating...';
            
            try {
                const formData = new FormData(document.getElementById('editContactForm'));
                
                console.log('Updating contact:', {
                    contactId: formData.get('contactId'),
                    sponsorId: formData.get('sponsorId'),
                    name: formData.get('name'),
                    email: formData.get('email'),
                    phone: formData.get('phone')
                });
                
                const response = await fetch('/Sponsors/UpdateContact', {
                    method: 'POST',
                    body: formData
                });
                
                console.log('Response status:', response.status);
                
                if (!response.ok) {
                    throw new Error(`Server returned ${response.status}: ${response.statusText}`);
                }
                
                const result = await response.json();
                
                if (result.success) {
                    const successDiv = document.getElementById('contactsSuccess');
                    successDiv.textContent = 'Contact updated successfully!';
                    successDiv.style.display = 'block';
                    
                    // Reset form and reload contacts
                    document.getElementById('editContactForm').reset();
                    await loadContacts(sponsorId);
                    
                    // Go back to step 1 after short delay
                    setTimeout(() => {
                        contactsGoToStep(1);
                    }, 1500);
                } else {
                    const errorDiv = document.getElementById('contactsError');
                    errorDiv.textContent = result.message || 'Failed to update contact.';
                    errorDiv.style.display = 'block';
                }
            } catch (error) {
                console.error('Error updating contact:', error);
                const errorDiv = document.getElementById('contactsError');
                errorDiv.textContent = `An error occurred: ${error.message || 'Please try again.'}`;
                errorDiv.style.display = 'block';
            } finally {
                updateBtn.disabled = false;
                updateBtn.innerHTML = originalText;
            }
        });
    }
</script>
}
