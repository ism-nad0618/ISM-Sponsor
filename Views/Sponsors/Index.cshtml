    function filterTable() {
        const searchInput = document.getElementById('searchInput').value.toLowerCase();
        const showInactive = document.getElementById('showInactiveSponsors').checked;
        const approvalFilter = document.getElementById('approvalFilter').value;
        const table = document.getElementById('sponsorsTable');
        const tbody = document.getElementById('sponsorsTableBody');
        const rows = tbody.getElementsByTagName('tr');
        const noResultsMsg = document.getElementById('noResultsMessage');
        let visibleCount = 0;
        
        for (let i = 0; i < rows.length; i++) {
            const row = rows[i];
            const sponsorId = row.getAttribute('data-sponsor-id')?.toLowerCase() || '';
            const sponsorName = row.getAttribute('data-sponsor-name')?.toLowerCase() || '';
            const legalName = row.getAttribute('data-legal-name')?.toLowerCase() || '';
            const status = row.getAttribute('data-status') || 'active';
            const approval = row.getAttribute('data-approval') || 'Approved';
            
            const matchesSearch = sponsorId.includes(searchInput) || 
                                sponsorName.includes(searchInput) || 
                                legalName.includes(searchInput);
            const matchesStatus = showInactive || status === 'active';
            const matchesApproval = approvalFilter === 'all' || approval === approvalFilter;
            
            if (matchesSearch && matchesStatus && matchesApproval) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        }
        
        // Show/hide no results message and table
        if (visibleCount === 0) {
            table.style.display = 'none';
            noResultsMsg.style.display = 'block';
        } else {
            table.style.display = 'table';
            noResultsMsg.style.display = 'none';
        }
    }
    
    function sortTable() {
        const select = document.getElementById('sortSelect');
        const [field, order] = select.value.split('-');
        const tbody = document.getElementById('sponsorsTableBody');
        const rows = Array.from(tbody.getElementsByTagName('tr'));
        
        rows.sort((a, b) => {
            let aValue, bValue;
            
            if (field === 'sponsorId') {
                aValue = a.getAttribute('data-sponsor-id') || '';
                bValue = b.getAttribute('data-sponsor-id') || '';
            } else if (field === 'sponsorName') {
                aValue = a.getAttribute('data-sponsor-name') || '';
                bValue = b.getAttribute('data-sponsor-name') || '';
            } else if (field === 'legalName') {
                aValue = a.getAttribute('data-legal-name') || '';
                bValue = b.getAttribute('data-legal-name') || '';
            }
            
            const comparison = aValue.localeCompare(bValue);
            return order === 'asc' ? comparison : -comparison;
        });
        
        // Clear and repopulate tbody
        tbody.innerHTML = '';
        rows.forEach(row => tbody.appendChild(row));
        
        // Reapply filter if search is active
        const searchInput = document.getElementById('searchInput').value;
        if (searchInput) {
            filterTable();
        }
    }
    
    function clearFilters() {
        // Reset all filter controls
        document.getElementById('searchInput').value = '';
        document.getElementById('showInactiveSponsors').checked = false;
        document.getElementById('approvalFilter').value = 'all';
        document.getElementById('sortSelect').value = 'sponsorName-asc';
        
        // Reapply sorting and filtering
        sortTable();
        filterTable();
    }
    
