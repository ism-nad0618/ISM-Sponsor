@model List<ISMSponsor.Models.Domain.Sponsor>
@{
    Layout = "_Layout";
    ViewData["Title"] = "All Sponsors";
}

<div class="page-header">
    <h1>All Sponsors</h1>
    <p class="page-subtitle">Review registered sponsor records.</p>
</div>

<div class="card">
    <h2 class="table-title">Sponsor Directory</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Sponsor ID</th>
                    <th>Sponsor Name</th>
                    <th>Legal Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.SponsorId</td>
                        <td>@s.SponsorName</td>
                        <td>@s.LegalName</td>
                        <td><a asp-action="Profile" asp-route-id="@s.SponsorId">View Profile</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
