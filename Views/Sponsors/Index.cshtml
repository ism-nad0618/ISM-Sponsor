@model List<ISMSponsor.Models.Domain.Sponsor>
@{
    Layout = "_Layout";
    ViewData["Title"] = "All Sponsors";
}

<div class="page-header">
    <h1>All Sponsors</h1>
    <p class="page-subtitle">Review registered sponsor records.</p>
</div>

@if (TempData["Success"] is string successText)
{
    <div class="alert alert-success">@successText</div>
}

@if (TempData["Error"] is string errorText)
{
    <div class="alert alert-error">@errorText</div>
}

<div class="card">
    <div class="page-header-actions">
        <h2 class="table-title">Sponsor Directory</h2>
        <a asp-action="Create" class="btn-primary btn-add">+ New Sponsor</a>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Sponsor ID</th>
                    <th>Sponsor Name</th>
                    <th>Legal Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.SponsorId</td>
                        <td>@s.SponsorName</td>
                        <td>@s.LegalName</td>
                        <td><a asp-action="Profile" asp-route-id="@s.SponsorId">View Profile</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
