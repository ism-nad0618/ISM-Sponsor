    async function loadContacts(sponsorId) {
        try {
            console.log('Loading contacts for sponsor:', sponsorId);
            const response = await fetch(`/Sponsors/GetContacts?sponsorId=${sponsorId}`);
            
            if (!response.ok) {
                throw new Error(`Server returned ${response.status}: ${response.statusText}`);
            }
            
            const contacts = await response.json();
            console.log('Loaded contacts:', contacts);
            currentSponsorContacts = contacts;
            
            const container = document.getElementById('contactsListContainer');
            
            if (!contacts || contacts.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; padding: 40px; background: #f9fafb; border-radius: 8px; border: 2px dashed #e5e7eb;">
                        <p style="color: var(--gray-500); margin: 0; font-size: 15px; font-weight: 600;">No Existing Record</p>
                        <p style="color: var(--gray-400); margin: 8px 0 0 0; font-size: 13px;">Click "Add New Contact" to add the first contact for this sponsor.</p>
                    </div>
                `;
                return;
            }
            
            let html = '<div style="display: grid; gap: 12px;">';
            contacts.forEach(contact => {
                const isActive = contact.isActive;
                const statusBadge = isActive 
                    ? '<span style="display: inline-block; padding: 2px 8px; background: #dff3e8; color: #0f6b41; border-radius: 4px; font-size: 11px; font-weight: 600; margin-left: 8px;">Active</span>'
                    : '<span style="display: inline-block; padding: 2px 8px; background: #f3f4f6; color: #6b7280; border-radius: 4px; font-size: 11px; font-weight: 600; margin-left: 8px;">Inactive</span>';
                
                const editButton = isActive 
                    ? `<button type="button" onclick="editContact(${contact.sponsorContactId}, '${escapeHtml(contact.name)}', '${escapeHtml(contact.email)}', '${escapeHtml(contact.phone)}')" 
                            style="padding: 6px 12px; background: white; color: var(--ism-blue); border: 1px solid var(--ism-blue); border-radius: 6px; font-size: 12px; cursor: pointer; font-weight: 500;">
                        ✎ Edit
                    </button>`
                    : '';
                
                const actionButton = isActive 
                    ? `<button type="button" onclick="deactivateContact(${contact.sponsorContactId})" 
                            style="padding: 6px 12px; background: white; color: var(--danger); border: 1px solid var(--danger); border-radius: 6px; font-size: 12px; cursor: pointer; font-weight: 500;">
                        ⊗ Deactivate
                    </button>`
                    : `<button type="button" onclick="reactivateContact(${contact.sponsorContactId})" 
                            style="padding: 6px 12px; background: white; color: #059669; border: 1px solid #059669; border-radius: 6px; font-size: 12px; cursor: pointer; font-weight: 500;">
                         Reactivate
                    </button>`;
                
                html += `
                    <div style="padding: 16px; background: ${isActive ? '#f9fafb' : '#fafafa'}; border-radius: 8px; border: 1px solid ${isActive ? '#e5e7eb' : '#e0e0e0'}; ${!isActive ? 'opacity: 0.8;' : ''}">
                        <div style="display: flex; justify-content: space-between; align-items: start;">
                            <div style="flex: 1;">
                                <h4 style="margin: 0 0 8px 0; color: var(--gray-900); font-size: 15px; font-weight: 600; display: flex; align-items: center;">
                                    ${escapeHtml(contact.name)}
                                    ${statusBadge}
                                </h4>
                                <p style="margin: 4px 0; color: var(--gray-600); font-size: 13px;">
                                    📧 ${escapeHtml(contact.email)}
                                </p>
                                <p style="margin: 4px 0; color: var(--gray-600); font-size: 13px;">
                                    📞 ${escapeHtml(contact.phone)}
                                </p>
                            </div>
                            <div style="display: flex; gap: 8px;">
                                ${editButton}
                                ${actionButton}
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            
            container.innerHTML = html;
        } catch (error) {
            console.error('Error loading contacts:', error);
            const container = document.getElementById('contactsListContainer');
            container.innerHTML = `
                <div style="text-align: center; padding: 20px; color: var(--danger);">
                    <p style="font-weight: 600; margin-bottom: 8px;">Error loading contacts</p>
                    <p style="font-size: 13px; color: var(--gray-600);">${error.message || 'Please try again.'}</p>
                </div>
            `;
        }
    }
    
