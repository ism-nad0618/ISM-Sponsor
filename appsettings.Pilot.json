{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "#{DatabaseConnectionString}#"
  },
  "KeyVault": {
    "Name": "#{KeyVault:Name}#"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "#{AzureAd:TenantId}#",
    "ClientId": "#{AzureAd:ClientId}#",
    "ClientSecret": "#{AzureAd:ClientSecret}#",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "Domain": "#{AzureAd:Domain}#",
    "AllowedDomains": ["ismschool.onmicrosoft.com", "ismmanila.org"]
  },
  "SponsorAuth": {
    "RequireEmailConfirmation": true,
    "PasswordRequirements": {
      "RequireDigit": true,
      "RequireNonAlphanumeric": true,
      "RequireUppercase": true,
      "RequiredLength": 8
    },
    "LockoutSettings": {
      "MaxFailedAccessAttempts": 5,
      "LockoutDurationMinutes": 30
    }
  },
  "Security": {
    "UseHttpsRedirection": true,
    "UseHsts": true,
    "CookieSecurePolicy": "Always",
    "AntiForgeryEnabled": true,
    "ContentSecurityPolicy": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:;",
    "RequireAuthenticatedByDefault": true
  },
  "Database": {
    "RunMigrationsOnStartup": false
  },
  "IntegrationEndpoints": {
    "PowerSchoolApiUrl": "#{Integration:PowerSchoolApiUrl}#",
    "StudentChargingPortalApiUrl": "#{Integration:StudentChargingPortalApiUrl}#",
    "NetSuiteApiUrl": "#{Integration:NetSuiteApiUrl}#",
    "OnlineBillingSystemApiUrl": "#{Integration:OnlineBillingSystemApiUrl}#",
    "SyncEnabled": true
  },
  "ApplicationInsights": {
    "InstrumentationKey": "#{ApplicationInsights:InstrumentationKey}#",
    "ConnectionString": "#{ApplicationInsights:ConnectionString}#"
  },
  "HealthChecks": {
    "Enabled": true,
    "DetailedErrors": false
  },
  "AllowedHosts": "*.ismmanila.org"
}
